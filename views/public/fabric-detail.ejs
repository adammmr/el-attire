  <!-- Independent Chat Widget -->
  <script>
    (function() {
      const widget = document.createElement('div');
      widget.className = 'chat-widget-overlay';
      widget.id = 'chatWidget';
      widget.innerHTML = `<style>
        .chat-widget-overlay { position:fixed;bottom:24px;right:24px;width:350px;max-width:90vw;height:440px;max-height:65vh;background:white;border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,0.2);z-index:300;display:flex;flex-direction:column;transform:translateY(20px) scale(0.95);opacity:0;pointer-events:none;transition:all 0.25s cubic-bezier(0.23,1,0.32,1);border:1px solid rgba(0,0,0,0.08); }
        .chat-widget-overlay.open { transform:translateY(0) scale(1);opacity:1;pointer-events:all; }
        .cw-h { padding:12px 14px;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between;border-radius:14px 14px 0 0;background:#fafafa; }
        .cw-ag { display:flex;align-items:center;gap:8px; }
        .cw-av { width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;color:white;font-weight:600;font-size:0.65rem; }
        .cw-on { display:flex;align-items:center;gap:4px;font-size:0.6rem;color:#10b981;font-weight:500; }
        .cw-ond { width:5px;height:5px;border-radius:50%;background:#10b981; }
        .cw-b { flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;background:#fafafa; }
        .cw-f { padding:10px 12px;border-top:1px solid #f3f4f6;display:flex;gap:6px;align-items:center; }
        .cw-f input { flex:1;padding:8px 12px;border:1px solid #e5e7eb;border-radius:18px;font-size:0.75rem;outline:none;background:white;font-family:inherit; }
        .cw-f input:focus { border-color:#9ca3af; }
        .cw-s { width:34px;height:34px;border-radius:50%;border:none;background:#374151;color:white;cursor:pointer;font-size:0.75rem;transition:all 0.15s;flex-shrink:0; }
        .cw-s:hover { background:#4b5563;transform:scale(1.05); }
        .cw-x { width:26px;height:26px;border-radius:50%;border:none;background:transparent;cursor:pointer;color:#9ca3af;font-size:0.9rem;display:flex;align-items:center;justify-content:center;transition:all 0.15s; }
        .cw-x:hover { background:#e5e7eb;color:#374151; }
        .cw-bub { padding:8px 12px;border-radius:12px;font-size:0.75rem;line-height:1.5;max-width:85%;animation:cwIn 0.3s ease-out; }
        @keyframes cwIn { from{opacity:0;transform:translateY(6px);} to{opacity:1;transform:translateY(0);} }
        .cw-bub.in { background:white;color:#374151;align-self:flex-start;border-bottom-left-radius:4px;box-shadow:0 1px 2px rgba(0,0,0,0.04); }
        .cw-bub.out { background:#374151;color:white;align-self:flex-end;border-bottom-right-radius:4px; }
        .cw-t { font-size:0.55rem;opacity:0.6;margin-top:3px;display:block; }
        .cw-q { display:flex;flex-wrap:wrap;gap:4px;padding:0 12px 8px; }
        .cw-q button { padding:5px 10px;border-radius:14px;border:1px solid #e5e7eb;background:white;font-size:0.65rem;cursor:pointer;transition:all 0.15s;color:#374151;font-family:inherit;white-space:nowrap; }
        .cw-q button:hover { background:#374151;color:white;border-color:#374151; }
        .cw-typ { display:flex;gap:3px;padding:8px 12px; }
        .cw-typ span { width:5px;height:5px;border-radius:50%;background:#9ca3af;animation:cwB 0.8s infinite; }
        .cw-typ span:nth-child(2){animation-delay:0.2s;} .cw-typ span:nth-child(3){animation-delay:0.4s;}
        @keyframes cwB { 0%,60%,100%{transform:translateY(0);} 30%{transform:translateY(-6px);} }
      </style>
      <div class="cw-h"><div class="cw-ag"><div class="cw-av">CS</div><div><p style="font-size:0.75rem;font-weight:500;color:#374151;margin:0;">Customer Support</p><div class="cw-on"><span class="cw-ond"></span> Online</div></div></div><button class="cw-x" id="cwClose">✕</button></div>
      <div class="cw-b" id="cwMessages"><div class="cw-bub in">Hello! 👋 How can we help with this fabric?<span class="cw-t">Just now</span></div></div>
      <div class="cw-q" id="cwQuick"><button onclick="window._cwSendQuick('Fabric width?')">📏 Width</button><button onclick="window._cwSendQuick('Shipping info')">🚚 Shipping</button><button onclick="window._cwSendQuick('Bulk pricing')">💰 Bulk</button><button onclick="window._cwSendQuick('Yardage for Agbada?')">📐 Yardage</button></div>
      <div class="cw-f"><input type="text" placeholder="Type message..." id="cwInput" onkeypress="if(event.key==='Enter')window._cwSend()"><button class="cw-s" onclick="window._cwSend()"><i class="fas fa-paper-plane"></i></button></div>`;
      document.body.appendChild(widget);

      let isOpen = false;
      const replies = {
        'width': '📏 45 inches wide. Standard for Nigerian fabrics. Works beautifully for all traditional styles.',
        'ship': '🚚 Free pickup at Lagos & Abuja. Home delivery: Lagos ₦5k (2-3 days), Abuja ₦10k (3-5 days).',
        'bulk': '💰 10+ yards = 10% off. 20+ yards = 15% off. Wholesale pricing available for 50+ yards.',
        'yardage': '📐 Agbada: 6-8 yards. Kaftan: 4-5 yards. Senator: 3-4 yards. Add 1 yard for matching cap.',
        'default': 'Thanks! A specialist will respond shortly. For urgent inquiries: +234 800 000 0000.'
      };
      function getReply(m) { const x=m.toLowerCase(); if(x.includes('width'))return replies.width; if(x.includes('ship')||x.includes('deliver'))return replies.ship; if(x.includes('bulk')||x.includes('discount'))return replies.bulk; if(x.includes('yard')||x.includes('agbada')||x.includes('kaftan'))return replies.yardage; return replies.default; }
      function getTime() { return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:true}); }
      function addMsg(text,type) { const msgs=document.getElementById('cwMessages'); const b=document.createElement('div'); b.className='cw-bub '+(type==='sent'?'out':'in'); b.innerHTML=text+'<span class="cw-t">'+getTime()+'</span>'; msgs.appendChild(b); msgs.scrollTop=msgs.scrollHeight; }
      function showTyping() { const msgs=document.getElementById('cwMessages'); const t=document.createElement('div'); t.className='cw-typ'; t.id='cwTyping'; t.innerHTML='<span></span><span></span><span></span>'; msgs.appendChild(t); msgs.scrollTop=msgs.scrollHeight; }
      function hideTyping() { const t=document.getElementById('cwTyping'); if(t)t.remove(); }
      window._cwSend=function(){ const input=document.getElementById('cwInput'); if(!input||!input.value.trim())return; addMsg(input.value.trim(),'sent'); const msg=input.value.trim(); input.value=''; showTyping(); setTimeout(()=>{hideTyping();addMsg(getReply(msg),'received');},700+Math.random()*1000); };
      window._cwSendQuick=function(text){ const input=document.getElementById('cwInput'); if(input)input.value=text; window._cwSend(); };
      function open(){ widget.classList.add('open'); isOpen=true; setTimeout(()=>document.getElementById('cwInput')?.focus(),300); }
      function close(){ widget.classList.remove('open'); isOpen=false; }
      function toggle(){ isOpen?close():open(); }
      document.getElementById('cwClose').addEventListener('click',close);
      document.addEventListener('keydown',function(e){ if(e.key==='Escape'&&isOpen)close(); });
      document.addEventListener('click',function(e){ if(isOpen&&!widget.contains(e.target)&&e.target.id!=='supportHeaderToggle'&&!document.getElementById('supportHeaderToggle')?.contains(e.target))close(); });
      document.getElementById('supportHeaderToggle').addEventListener('click',toggle);
    })();
  </script>

  <!-- Product Script -->
  <script>
    (function() {
      const product = {
        id: 1, name: 'Royal Blue Aso Oke', category: 'aso-oke', price: 120000, unit: 'yard',
        images: ['photos/fabrics/f1.jpg','photos/fabrics/f2.jpg','photos/fabrics/f3.jpg','photos/fabrics/f4.jpg'],
        tag: 'Premium', minQty: 3, maxQty: 45
      };

      let cart = JSON.parse(localStorage.getItem('elattire_cart') || '[]');
      function saveCart() { localStorage.setItem('elattire_cart', JSON.stringify(cart)); }

      const zoomContainer = document.getElementById('zoomContainer');
      const mainImage = document.getElementById('mainImage');
      zoomContainer.addEventListener('mousemove', function(e) {
        const rect = this.getBoundingClientRect();
        this.style.setProperty('--zoom-x', ((e.clientX - rect.left) / rect.width) * 100 + '%');
        this.style.setProperty('--zoom-y', ((e.clientY - rect.top) / rect.height) * 100 + '%');
      });
      zoomContainer.addEventListener('mouseleave', function() {
        this.style.setProperty('--zoom-x', '50%');
        this.style.setProperty('--zoom-y', '50%');
      });

      document.querySelectorAll('.thumb-item').forEach(thumb => {
        thumb.addEventListener('click', function() {
          const index = parseInt(this.dataset.img);
          mainImage.src = product.images[index];
          mainImage.onerror = function() { this.src = 'https://placehold.co/600x480/e5e7eb/9ca3af?text=Fabric'; };
          document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active-thumb'));
          this.classList.add('active-thumb');
        });
      });
      mainImage.onerror = function() { this.src = 'https://placehold.co/600x480/e5e7eb/9ca3af?text=Fabric'; };

      const qtyInput = document.getElementById('qtyInput');
      const totalPrice = document.getElementById('totalPrice');
      function updateTotal() { const qty = parseInt(qtyInput.value) || product.minQty; totalPrice.textContent = (product.price * qty).toLocaleString(); }
      document.getElementById('qtyPlus').addEventListener('click', () => { qtyInput.value = Math.min(product.maxQty, parseInt(qtyInput.value) + 1); updateTotal(); });
      document.getElementById('qtyMinus').addEventListener('click', () => { qtyInput.value = Math.max(product.minQty, parseInt(qtyInput.value) - 1); updateTotal(); });

      document.getElementById('addToCartBtn').addEventListener('click', () => {
        const qty = parseInt(qtyInput.value);
        const existing = cart.find(i => i.id === product.id);
        if (existing) { existing.qty += qty; }
        else { cart.push({ ...product, qty }); }
        saveCart(); updateCart();
        const toast = document.getElementById('toast');
        toast.textContent = `✓ ${qty} yard(s) added — ₦${(product.price * qty).toLocaleString()}`;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3000);
      });

      document.getElementById('wishlistBtn').addEventListener('click', function() {
        const icon = this.querySelector('i');
        icon.classList.toggle('far'); icon.classList.toggle('fas'); icon.classList.toggle('text-red-500');
        const toast = document.getElementById('toast');
        toast.textContent = icon.classList.contains('fas') ? '♥ Added to wishlist' : 'Removed from wishlist';
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2000);
      });

      function updateCart() {
        const total = cart.reduce((s,i) => s + i.qty, 0);
        document.getElementById('cartBadge').textContent = total;
        document.getElementById('drawerCount').textContent = `${total} item${total !== 1 ? 's' : ''}`;
        document.getElementById('drawerTotal').textContent = '₦' + cart.reduce((s,i) => s + i.price * i.qty, 0).toLocaleString();
        
        document.getElementById('drawerItems').innerHTML = cart.length === 0 ? 
          '<p class="text-neutral-400 text-[0.8rem] text-center py-16">Your bag is empty</p>' : 
          cart.map(item => `
            <div class="flex gap-3 items-start border-b border-gray-50 pb-3">
              <img src="${item.images[0]}" class="w-14 h-14 object-cover rounded" alt="${item.name}" onerror="this.src='https://placehold.co/56x56/e5e7eb/9ca3af'">
              <div class="flex-1 min-w-0">
                <p class="text-[0.75rem] font-medium truncate">${item.name}</p>
                <p class="text-[0.65rem] text-neutral-400">₦${item.price.toLocaleString()}/${item.unit}</p>
                <div class="flex items-center gap-2 mt-1">
                  <button class="border px-1.5 py-0.5 text-[0.6rem] rounded cq-minus" data-id="${item.id}">−</button>
                  <span class="text-[0.7rem] font-medium">${item.qty}</span>
                  <button class="border px-1.5 py-0.5 text-[0.6rem] rounded cq-plus" data-id="${item.id}">+</button>
                </div>
              </div>
              <button class="text-neutral-400 hover:text-red-500 cremove" data-id="${item.id}"><i class="fas fa-trash text-[0.6rem]"></i></button>
            </div>
          `).join('');
        
        document.querySelectorAll('.cq-plus').forEach(b => b.addEventListener('click', () => {
          const item = cart.find(i => i.id === parseInt(b.dataset.id));
          if (item) { item.qty = Math.min(item.maxQty || 50, item.qty + 1); saveCart(); updateCart(); }
        }));
        document.querySelectorAll('.cq-minus').forEach(b => b.addEventListener('click', () => {
          const item = cart.find(i => i.id === parseInt(b.dataset.id));
          if (item && item.qty > (item.minQty || 1)) { item.qty--; }
          else { cart = cart.filter(i => i.id !== parseInt(b.dataset.id)); }
          saveCart(); updateCart();
        }));
        document.querySelectorAll('.cremove').forEach(b => b.addEventListener('click', () => {
          cart = cart.filter(i => i.id !== parseInt(b.dataset.id));
          saveCart(); updateCart();
        }));
      }

      document.getElementById('cartIcon').addEventListener('click', () => {
        document.getElementById('cartDrawer').classList.add('open');
        document.getElementById('cartDrawerOverlay').classList.add('open');
      });
      document.getElementById('closeDrawer').addEventListener('click', () => {
        document.getElementById('cartDrawer').classList.remove('open');
        document.getElementById('cartDrawerOverlay').classList.remove('open');
      });
      document.getElementById('cartDrawerOverlay').addEventListener('click', () => {
        document.getElementById('cartDrawer').classList.remove('open');
        document.getElementById('cartDrawerOverlay').classList.remove('open');
      });

      const scrollContainer = document.getElementById('relatedScroll');
      document.getElementById('scrollLeft').addEventListener('click', () => scrollContainer.scrollBy({ left: -200, behavior: 'smooth' }));
      document.getElementById('scrollRight').addEventListener('click', () => scrollContainer.scrollBy({ left: 200, behavior: 'smooth' }));

      updateCart();
    })();
  </script>
