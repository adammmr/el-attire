

  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="index.html" class="inline-block no-underline">
        <img src="photos/logo_only_bk.png" alt="EL-ATTIRE" class="nav-logo mx-auto mb-2" onerror="this.style.display='none'">
      </a>
      <p class="text-[0.62rem] text-neutral-400 tracking-widest uppercase">Bespoke Nigerian Tailoring</p>
    </div>

    <div class="glass-panel p-8">
      <div id="resetFormContent">
        <h1 class="text-2xl font-light section-title text-[#374151] mb-1">Reset Password</h1>
        <p class="text-[0.78rem] text-neutral-400 mb-5">Create a new password for your account.</p>
        <div class="error-msg mb-4" id="resetError"><i class="fas fa-exclamation-circle mr-2"></i><span id="resetErrorText"></span></div>
        
        <form id="resetForm" class="space-y-4">
          <div>
            <label class="text-[0.62rem] font-medium text-neutral-400 uppercase tracking-wider block mb-1">New Password</label>
            <div class="relative">
              <input type="password" id="newPassword" placeholder="Enter new password" required class="input-lux pr-10">
              <button type="button" class="password-toggle" id="toggleNew"><i class="far fa-eye"></i></button>
            </div>
            <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
            <p class="text-[0.62rem] text-neutral-400 mt-1" id="strengthText">Enter a password</p>
          </div>

          <div class="space-y-1.5">
            <div class="requirement" id="reqLength"><i class="fas fa-circle text-[5px]"></i> At least 8 characters</div>
            <div class="requirement" id="reqUpper"><i class="fas fa-circle text-[5px]"></i> At least 1 uppercase letter</div>
            <div class="requirement" id="reqNumber"><i class="fas fa-circle text-[5px]"></i> At least 1 number</div>
            <div class="requirement" id="reqSpecial"><i class="fas fa-circle text-[5px]"></i> At least 1 special character</div>
          </div>

          <div>
            <label class="text-[0.62rem] font-medium text-neutral-400 uppercase tracking-wider block mb-1">Confirm Password</label>
            <div class="relative">
              <input type="password" id="confirmPassword" placeholder="Confirm new password" required class="input-lux pr-10">
              <button type="button" class="password-toggle" id="toggleConfirm"><i class="far fa-eye"></i></button>
            </div>
            <p class="text-[0.65rem] mt-1" id="matchText"></p>
          </div>

          <button type="submit" class="btn-primary text-[0.78rem] tracking-wider">Reset Password</button>
        </form>
      </div>

      <div id="successContent" class="hidden text-center py-4">
        <div class="w-14 h-14 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-check text-emerald-600 text-xl"></i>
        </div>
        <h2 class="text-xl font-medium section-title text-[#374151] mb-2">Password Reset!</h2>
        <p class="text-[0.75rem] text-neutral-400 mb-5">Your password has been successfully updated. You can now sign in with your new password.</p>
        <a href="login.html" class="btn-primary text-[0.78rem]">Sign In</a>
      </div>

      <div class="text-center mt-5" id="backLink">
        <a href="login.html" class="text-[0.7rem] text-neutral-400 hover:text-[#374151] transition-colors"><i class="fas fa-arrow-left mr-1"></i> Back to Sign In</a>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var newPass = document.getElementById('newPassword');
      var confirmPass = document.getElementById('confirmPassword');
      var strengthFill = document.getElementById('strengthFill');
      var strengthText = document.getElementById('strengthText');

      function setupToggle(toggleId, inputId) {
        document.getElementById(toggleId).addEventListener('click', function() {
          var input = document.getElementById(inputId);
          var type = input.getAttribute('type') === 'password' ? 'text' : 'password';
          input.setAttribute('type', type);
          this.querySelector('i').classList.toggle('fa-eye');
          this.querySelector('i').classList.toggle('fa-eye-slash');
        });
      }
      setupToggle('toggleNew', 'newPassword');
      setupToggle('toggleConfirm', 'confirmPassword');

      var requirements = {
        length: { el: document.getElementById('reqLength'), regex: /.{8,}/ },
        upper: { el: document.getElementById('reqUpper'), regex: /[A-Z]/ },
        number: { el: document.getElementById('reqNumber'), regex: /[0-9]/ },
        special: { el: document.getElementById('reqSpecial'), regex: /[!@#$%^&*(),.?":{}|<>]/ }
      };

      function checkStrength(password) {
        var score = 0;
        Object.keys(requirements).forEach(function(key) {
          var req = requirements[key];
          if (req.regex.test(password)) {
            req.el.classList.add('met');
            req.el.querySelector('i').classList.remove('fa-circle');
            req.el.querySelector('i').classList.add('fa-check-circle');
            score++;
          } else {
            req.el.classList.remove('met');
            req.el.querySelector('i').classList.add('fa-circle');
            req.el.querySelector('i').classList.remove('fa-check-circle');
          }
        });
        var pct = (score / 4) * 100;
        strengthFill.style.width = pct + '%';
        if (score === 0) { strengthFill.style.background = '#e5e7eb'; strengthText.textContent = 'Enter a password'; }
        else if (score === 1) { strengthFill.style.background = '#ef4444'; strengthText.textContent = 'Weak'; }
        else if (score === 2) { strengthFill.style.background = '#f59e0b'; strengthText.textContent = 'Fair'; }
        else if (score === 3) { strengthFill.style.background = '#84cc16'; strengthText.textContent = 'Good'; }
        else { strengthFill.style.background = '#10b981'; strengthText.textContent = 'Strong'; }
        return score;
      }

      newPass.addEventListener('input', function() { checkStrength(this.value); checkMatch(); });
      confirmPass.addEventListener('input', checkMatch);

      function checkMatch() {
        var np = newPass.value, cp = confirmPass.value;
        if (!cp) { document.getElementById('matchText').textContent = ''; }
        else if (np === cp) { document.getElementById('matchText').textContent = '✓ Passwords match'; document.getElementById('matchText').className = 'text-[0.65rem] mt-1 text-emerald-600'; }
        else { document.getElementById('matchText').textContent = '✗ Passwords do not match'; document.getElementById('matchText').className = 'text-[0.65rem] mt-1 text-red-500'; }
      }

      document.getElementById('resetForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var np = newPass.value, cp = confirmPass.value;
        var errEl = document.getElementById('resetError'), errTxt = document.getElementById('resetErrorText');
        if (np.length < 8) { errTxt.textContent = 'Password must be at least 8 characters.'; errEl.style.display = 'block'; return; }
        if (checkStrength(np) < 3) { errTxt.textContent = 'Please create a stronger password.'; errEl.style.display = 'block'; return; }
        if (np !== cp) { errTxt.textContent = 'Passwords do not match.'; errEl.style.display = 'block'; return; }
        errEl.style.display = 'none';
        document.getElementById('resetFormContent').classList.add('hidden');
        document.getElementById('successContent').classList.remove('hidden');
        document.getElementById('backLink').classList.add('hidden');
      });

      [newPass, confirmPass].forEach(function(i) {
        i.addEventListener('input', function() { document.getElementById('resetError').style.display = 'none'; });
      });
    })();
  </script>
