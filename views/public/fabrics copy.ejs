  <script>
    (function() {
      // Fabric data with local photos (f1-f16.jpg in photos/fabrics/)
      const fabricData = [
        { id:1, name:'Royal Blue Aso Oke', category:'aso-oke', price:120000, unit:'yd', images:['photos/fabrics/f1.jpg','photos/fabrics/f2.jpg','photos/fabrics/f3.jpg'], tag:'Premium', badge:'Bestseller', isNew:false, description:'Handwoven premium Aso Oke from the Yoruba tradition. Rich royal blue with metallic thread accents.', width:'45"', composition:'Cotton / Metallic Thread', weight:'280 gsm', care:'Dry Clean', colors:['#1a3a5c','#c9a84c','#f5f5f0'] },
        { id:2, name:'Cream Damask Weave', category:'damask', price:95000, unit:'yd', images:['photos/fabrics/f4.jpg','photos/fabrics/f5.jpg','photos/fabrics/f6.jpg'], tag:'Italian', badge:'', isNew:false, description:'Italian damask with subtle floral patterns. Beautiful drape and sheen for modern Senator styles.', width:'54"', composition:'Cotton Damask', weight:'250 gsm', care:'Dry Clean', colors:['#f5f0e8','#e8ddd0','#d4c8b8'] },
        { id:3, name:'Emerald Silk Satin', category:'silk', price:185000, unit:'yd', images:['photos/fabrics/f7.jpg','photos/fabrics/f8.jpg','photos/fabrics/f9.jpg'], tag:'Luxury', badge:'New', isNew:true, description:'Pure silk satin in deep emerald. Liquid-like drape with luminous surface.', width:'44"', composition:'100% Silk', weight:'180 gsm', care:'Dry Clean Only', colors:['#0a5c3a','#1a7a4a','#c9e8d0'] },
        { id:4, name:'Gold Brocade', category:'brocade', price:210000, unit:'yd', images:['photos/fabrics/f10.jpg','photos/fabrics/f11.jpg','photos/fabrics/f12.jpg'], tag:'Exclusive', badge:'', isNew:false, description:'Opulent gold brocade with raised patterns. Heavyweight and regal for grand Agbada.', width:'48"', composition:'Silk Blend Brocade', weight:'350 gsm', care:'Dry Clean', colors:['#c9a84c','#8b6914','#fff8dc'] },
        { id:5, name:'White Cotton Lawn', category:'cotton', price:45000, unit:'yd', images:['photos/fabrics/f13.jpg','photos/fabrics/f14.jpg','photos/fabrics/f15.jpg'], tag:'Essential', badge:'', isNew:false, description:'Lightweight cotton lawn in crisp white. Breathable and versatile for daily wear.', width:'45"', composition:'100% Cotton', weight:'150 gsm', care:'Machine Wash', colors:['#ffffff','#f8f8f8','#f0f0f0'] },
        { id:6, name:'Burgundy Aso Oke', category:'aso-oke', price:135000, unit:'yd', images:['photos/fabrics/f16.jpg','photos/fabrics/f1.jpg','photos/fabrics/f2.jpg'], tag:'Heritage', badge:'', isNew:false, description:'Deep burgundy Aso Oke with traditional stripe patterns for ceremonial occasions.', width:'45"', composition:'Cotton / Silk Blend', weight:'290 gsm', care:'Dry Clean', colors:['#4a0a1a','#6a1a2a','#f0e0e5'] },
        { id:7, name:'Navy Damask', category:'damask', price:105000, unit:'yd', images:['photos/fabrics/f3.jpg','photos/fabrics/f4.jpg','photos/fabrics/f5.jpg'], tag:'Classic', badge:'New', isNew:true, description:'Navy blue damask with subtle geometric weave. Sophisticated and timeless.', width:'54"', composition:'Cotton Damask', weight:'260 gsm', care:'Dry Clean', colors:['#0a1a3a','#1a2a5a','#c0c8d8'] },
        { id:8, name:'Ivory Silk Chiffon', category:'silk', price:165000, unit:'yd', images:['photos/fabrics/f6.jpg','photos/fabrics/f7.jpg','photos/fabrics/f8.jpg'], tag:'Delicate', badge:'New', isNew:true, description:'Sheer ivory silk chiffon with ethereal float. Perfect for layering.', width:'42"', composition:'100% Silk', weight:'80 gsm', care:'Dry Clean Only', colors:['#fffff0','#faf5e8','#f0e8d8'] },
        { id:9, name:'Black Lace Panel', category:'lace', price:150000, unit:'panel', images:['photos/fabrics/f9.jpg','photos/fabrics/f10.jpg','photos/fabrics/f11.jpg'], tag:'Artisan', badge:'', isNew:false, description:'Hand-crafted black lace with intricate floral motifs.', width:'36"', composition:'Cotton Lace', weight:'120 gsm', care:'Hand Wash', colors:['#0a0a0a','#1a1a1a','#2a2a2a'] },
        { id:10, name:'Sage Cotton Blend', category:'cotton', price:55000, unit:'yd', images:['photos/fabrics/f12.jpg','photos/fabrics/f13.jpg','photos/fabrics/f14.jpg'], tag:'Breathable', badge:'New', isNew:true, description:'Soft sage green cotton blend with subtle texture for casual Kaftans.', width:'45"', composition:'Cotton / Linen Blend', weight:'170 gsm', care:'Machine Wash', colors:['#8a9a7a','#aabaaa','#d0d8c8'] },
        { id:11, name:'Purple Brocade', category:'brocade', price:230000, unit:'yd', images:['photos/fabrics/f15.jpg','photos/fabrics/f16.jpg','photos/fabrics/f1.jpg'], tag:'Regal', badge:'', isNew:false, description:'Royal purple brocade with gold undertones for statement pieces.', width:'48"', composition:'Silk Blend Brocade', weight:'360 gsm', care:'Dry Clean', colors:['#3a0a4a','#5a1a6a','#d0c0d8'] },
        { id:12, name:'Champagne Aso Oke', category:'aso-oke', price:140000, unit:'yd', images:['photos/fabrics/f2.jpg','photos/fabrics/f3.jpg','photos/fabrics/f4.jpg'], tag:'Celebration', badge:'New', isNew:true, description:'Champagne-toned Aso Oke with subtle shimmer for weddings and galas.', width:'45"', composition:'Cotton / Metallic Thread', weight:'275 gsm', care:'Dry Clean', colors:['#f5e8c8','#e8d8a8','#d4c898'] },
      ];

      let cart = [];
      let currentFilter = 'all';
      let visibleCount = 6;
      let detailIndex = -1;

      const gridContainer = document.getElementById('fabricGridContainer');
      const cartBadge = document.getElementById('cartBadge');
      const cartDrawer = document.getElementById('cartDrawer');
      const cartDrawerOverlay = document.getElementById('cartDrawerOverlay');
      const drawerItems = document.getElementById('drawerItems');
      const drawerCount = document.getElementById('drawerCount');
      const drawerTotal = document.getElementById('drawerTotal');
      const detailModalOverlay = document.getElementById('detailModalOverlay');
      const detailModal = document.getElementById('detailModal');

      function showToast(msg) {
        const t = document.getElementById('toast');
        t.textContent = msg; t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2500);
      }

      function startAutoSlide(card) {
        const slides = card.querySelectorAll('.fabric-slide');
        const dots = card.querySelectorAll('.fabric-dot');
        if (slides.length < 2) return;
        let index = 0, interval;
        function show(i) { slides.forEach(s => s.classList.remove('active')); dots.forEach(d => d.classList.remove('active-dot')); slides[i].classList.add('active'); dots[i].classList.add('active-dot'); }
        card.addEventListener('mouseenter', () => { interval = setInterval(() => { index = (index+1) % slides.length; show(index); }, 1200); });
        card.addEventListener('mouseleave', () => { clearInterval(interval); index = 0; show(0); });
        show(0);
      }

      function openDetailModal(index) {
        detailIndex = index;
        const f = fabricData[index];
        if (!f) return;
        detailModal.innerHTML = `
          <div style="height:400px;"><img src="${f.images[0]}" alt="${f.name}" class="w-full h-full object-cover" id="detailMainImage"></div>
          <div class="p-8 flex flex-col justify-center">
            <span class="text-xs uppercase tracking-[0.2em] text-neutral-400">${f.category.replace('-',' ')} · ${f.tag}</span>
            <h2 class="text-2xl font-light section-title mt-2 mb-3">${f.name}</h2>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">${f.description}</p>
            <div class="space-y-2 text-sm mb-4">
              <div class="flex justify-between"><span class="text-neutral-400">Width</span><span>${f.width}</span></div>
              <div class="flex justify-between"><span class="text-neutral-400">Composition</span><span>${f.composition}</span></div>
              <div class="flex justify-between"><span class="text-neutral-400">Weight</span><span>${f.weight}</span></div>
              <div class="flex justify-between"><span class="text-neutral-400">Care</span><span>${f.care}</span></div>
            </div>
            <div class="flex gap-2 mb-4">${f.colors.map(c => `<span class="swatch" style="background:${c};"></span>`).join('')}</div>
            <p class="text-2xl font-semibold mb-2">₦${f.price.toLocaleString()}<span class="text-sm font-normal text-neutral-500">/${f.unit}</span></p>
            <div class="flex gap-2 mb-4"><span class="text-xs uppercase tracking-wider font-medium">Qty:</span><div class="flex items-center border"><button class="px-3 py-1 detail-qty-minus">−</button><span class="px-4 py-1 font-semibold detail-qty-val">3</span><button class="px-3 py-1 detail-qty-plus">+</button></div></div>
            <div class="flex gap-3"><button class="btn-black px-6 py-3 uppercase text-xs flex-1 detail-add-cart" data-id="${f.id}">Add to Cart — ₦<span class="detail-total-price">${(f.price*3).toLocaleString()}</span></button><button class="btn-outline px-4 py-3 aspect-square flex items-center justify-center"><i class="far fa-heart"></i></button></div>
            <div class="flex gap-2 mt-3">${f.images.map((img,i) => `<img src="${img}" class="w-12 h-12 object-cover cursor-pointer border-2 ${i===0?'border-black':'border-transparent'} detail-thumb" data-img="${i}">`).join('')}</div>
          </div>`;
        detailModalOverlay.classList.add('open'); document.body.style.overflow = 'hidden';
        detailModal.querySelectorAll('.detail-thumb').forEach(thumb => { thumb.addEventListener('click', function() { detailModal.querySelectorAll('.detail-thumb').forEach(t => t.classList.remove('border-black')); this.classList.add('border-black'); document.getElementById('detailMainImage').src = f.images[parseInt(this.dataset.img)]; }); });
        const qtyVal = detailModal.querySelector('.detail-qty-val');
        const totalPriceEl = detailModal.querySelector('.detail-total-price');
        detailModal.querySelector('.detail-qty-plus').addEventListener('click', () => { let v = parseInt(qtyVal.textContent); qtyVal.textContent = Math.min(50, v+1); totalPriceEl.textContent = (f.price * parseInt(qtyVal.textContent)).toLocaleString(); });
        detailModal.querySelector('.detail-qty-minus').addEventListener('click', () => { let v = parseInt(qtyVal.textContent); if(v>1) qtyVal.textContent = v-1; totalPriceEl.textContent = (f.price * parseInt(qtyVal.textContent)).toLocaleString(); });
        detailModal.querySelector('.detail-add-cart').addEventListener('click', function() { const qty = parseInt(qtyVal.textContent); for(let i=0; i<qty; i++) addToCart(f.id); showToast(`✓ ${qty} yard(s) of ${f.name} added`); closeDetailModal(); });
      }

      function closeDetailModal() { detailModalOverlay.classList.remove('open'); document.body.style.overflow = ''; detailIndex = -1; }
      document.getElementById('detailModalClose').addEventListener('click', closeDetailModal);
      detailModalOverlay.addEventListener('click', function(e) { if(e.target === this) closeDetailModal(); });
      document.getElementById('detailModalPrev').addEventListener('click', () => { if (detailIndex > 0) openDetailModal(detailIndex - 1); });
      document.getElementById('detailModalNext').addEventListener('click', () => { if (detailIndex < fabricData.length - 1) openDetailModal(detailIndex + 1); });
      document.addEventListener('keydown', function(e) { if (!detailModalOverlay.classList.contains('open')) return; if (e.key === 'Escape') closeDetailModal(); if (e.key === 'ArrowLeft' && detailIndex > 0) openDetailModal(detailIndex - 1); if (e.key === 'ArrowRight' && detailIndex < fabricData.length - 1) openDetailModal(detailIndex + 1); });

      function renderFabrics(filter = 'all', count = visibleCount) {
        let filtered = filter === 'all' ? fabricData : filter === 'new' ? fabricData.filter(f => f.isNew) : fabricData.filter(f => f.category === filter);
        const display = filtered.slice(0, count);
        let html = '';
        display.forEach((fabric) => {
          const actualIndex = fabricData.indexOf(fabric);
          const isLarge = fabric.isNew && display.filter(f=>f.isNew).indexOf(fabric) < 2;
          if (isLarge) {
            html += `<div class="large-card fabric-card" data-index="${actualIndex}" style="grid-row:span 2;grid-column:span 2;"><div class="fabric-image-container" style="height:100%;">${fabric.images.map((img,j) => `<img src="${img}" class="fabric-slide ${j===0?'active':''}" alt="${fabric.name}">`).join('')}<div class="fabric-dots">${fabric.images.map((_,j) => `<span class="fabric-dot ${j===0?'active-dot':''}"></span>`).join('')}</div><span class="fabric-tag">${fabric.tag}</span><span class="fabric-badge">NEW ARRIVAL</span><button class="quick-add-btn" data-id="${fabric.id}">Add to Cart</button></div><div class="large-card-overlay"><span class="text-xs uppercase tracking-wider opacity-70">${fabric.category.replace('-',' ')}</span><h4 class="text-2xl font-light section-title mt-1">${fabric.name}</h4><p class="text-xl font-semibold mt-1">₦${fabric.price.toLocaleString()}/${fabric.unit}</p></div></div>`;
          } else {
            html += `<div class="fabric-card" data-index="${actualIndex}"><div class="fabric-image-container">${fabric.images.map((img,j) => `<img src="${img}" class="fabric-slide ${j===0?'active':''}" alt="${fabric.name}">`).join('')}<div class="fabric-dots">${fabric.images.map((_,j) => `<span class="fabric-dot ${j===0?'active-dot':''}"></span>`).join('')}</div><span class="fabric-tag">${fabric.tag}</span>${fabric.badge?`<span class="fabric-badge">${fabric.badge}</span>`:''}<button class="quick-add-btn" data-id="${fabric.id}">Add to Cart</button></div><div class="p-4"><h4 class="font-medium text-sm">${fabric.name}</h4><div class="flex justify-between items-center mt-1"><span class="font-semibold text-sm">₦${fabric.price.toLocaleString()}/${fabric.unit}</span><span class="text-xs text-neutral-400 uppercase">${fabric.category.replace('-',' ')}</span></div></div></div>`;
          }
        });
        gridContainer.innerHTML = html;
        document.querySelectorAll('.fabric-card').forEach(card => startAutoSlide(card));
        document.querySelectorAll('.fabric-card').forEach(card => { card.addEventListener('click', function(e) { if (e.target.closest('.quick-add-btn')) return; openDetailModal(parseInt(this.dataset.index)); }); });
        document.querySelectorAll('.quick-add-btn').forEach(btn => { btn.addEventListener('click', function(e) { e.stopPropagation(); addToCart(parseInt(this.dataset.id)); }); });
        document.getElementById('loadMoreBtn').style.display = filtered.length <= count ? 'none' : 'inline-block';
      }

      function addToCart(id) { const fabric = fabricData.find(f => f.id === id); if (!fabric) return; const existing = cart.find(i => i.id === id); existing ? existing.qty++ : cart.push({...fabric, qty:1}); updateCart(); }
      function updateCart() {
        const totalItems = cart.reduce((s,i) => s + i.qty, 0);
        cartBadge.textContent = totalItems; drawerCount.textContent = totalItems;
        drawerTotal.textContent = '₦' + cart.reduce((s,i) => s + i.price * i.qty, 0).toLocaleString();
        drawerItems.innerHTML = cart.length === 0 ? '<p class="text-neutral-400 text-sm text-center py-16">Your bag is empty</p>' : cart.map(item => `<div class="flex gap-3 items-start border-b pb-3"><img src="${item.images[0]}" class="w-16 h-16 object-cover" alt="${item.name}"><div class="flex-1"><p class="text-sm font-medium">${item.name}</p><p class="text-xs text-neutral-500">₦${item.price.toLocaleString()}/${item.unit}</p><div class="flex items-center gap-2 mt-1"><button class="border px-2 py-0.5 text-xs cq-minus" data-id="${item.id}">−</button><span class="text-sm">${item.qty}</span><button class="border px-2 py-0.5 text-xs cq-plus" data-id="${item.id}">+</button></div></div><button class="text-neutral-400 hover:text-red-500 cremove" data-id="${item.id}"><i class="fas fa-trash text-xs"></i></button></div>`).join('');
        document.querySelectorAll('.cq-plus').forEach(b => b.addEventListener('click', () => { const item = cart.find(i => i.id === parseInt(b.dataset.id)); if(item) item.qty++; updateCart(); }));
        document.querySelectorAll('.cq-minus').forEach(b => b.addEventListener('click', () => { const item = cart.find(i => i.id === parseInt(b.dataset.id)); if(item && item.qty > 1) item.qty--; else cart = cart.filter(i => i.id !== parseInt(b.dataset.id)); updateCart(); }));
        document.querySelectorAll('.cremove').forEach(b => b.addEventListener('click', () => { cart = cart.filter(i => i.id !== parseInt(b.dataset.id)); updateCart(); }));
      }

      // Featured carousel
      const featCarousel = document.getElementById('featuredCarousel');
      featCarousel.innerHTML = fabricData.slice(0,5).map(f => `<div class="featured-card" data-index="${fabricData.indexOf(f)}"><img src="${f.images[0]}" alt="${f.name}"><div class="p-4"><span class="text-xs text-neutral-400 uppercase tracking-wider">${f.category.replace('-',' ')}</span><h4 class="font-medium mt-1">${f.name}</h4><p class="font-semibold text-sm mt-1">₦${f.price.toLocaleString()}/${f.unit}</p></div></div>`).join('');
      featCarousel.querySelectorAll('.featured-card').forEach(card => { card.addEventListener('click', () => openDetailModal(parseInt(card.dataset.index))); });
      document.getElementById('featScrollLeft').addEventListener('click', () => featCarousel.scrollBy({left:-340,behavior:'smooth'}));
      document.getElementById('featScrollRight').addEventListener('click', () => featCarousel.scrollBy({left:340,behavior:'smooth'}));

      // Hero carousel
      let heroIndex = 0;
      const heroSlides = document.querySelectorAll('.hero-slide');
      const heroDots = document.querySelectorAll('.hero-dot');
      function showHero(i) { heroSlides.forEach(s => s.classList.remove('active')); heroDots.forEach(d => d.classList.remove('active-dot')); heroSlides[i].classList.add('active'); heroDots[i].classList.add('active-dot'); heroIndex = i; }
      document.getElementById('heroNext').addEventListener('click', () => showHero((heroIndex+1)%heroSlides.length));
      document.getElementById('heroPrev').addEventListener('click', () => showHero((heroIndex-1+heroSlides.length)%heroSlides.length));
      heroDots.forEach(d => d.addEventListener('click', () => showHero(parseInt(d.dataset.index))));
      setInterval(() => showHero((heroIndex+1)%heroSlides.length), 5000);

      // Cart drawer
      document.getElementById('cartIcon').addEventListener('click', () => { cartDrawer.classList.add('open'); cartDrawerOverlay.classList.add('open'); });
      document.getElementById('closeDrawer').addEventListener('click', () => { cartDrawer.classList.remove('open'); cartDrawerOverlay.classList.remove('open'); });
      cartDrawerOverlay.addEventListener('click', () => { cartDrawer.classList.remove('open'); cartDrawerOverlay.classList.remove('open'); });

      // Filters
      document.querySelectorAll('.filter-chip').forEach(chip => chip.addEventListener('click', function() { document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active-chip')); this.classList.add('active-chip'); currentFilter = this.dataset.filter; visibleCount = 6; renderFabrics(currentFilter, visibleCount); }));
      document.getElementById('loadMoreBtn').addEventListener('click', () => { visibleCount += 6; renderFabrics(currentFilter, visibleCount); });

      renderFabrics();
      updateCart();
    })();
  </script>
