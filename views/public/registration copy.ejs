  <script>
    (function() {
      const mannequinInner = document.getElementById('mannequinInner');
      const rotationSlider = document.getElementById('rotationSlider');
      const viewLabel = document.getElementById('viewLabel');
      const indicator = document.getElementById('mannequinIndicator');
      const mannequinContainer = document.getElementById('mannequinContainer');
      const btnFront = document.getElementById('btnFront');
      const btnBack = document.getElementById('btnBack');
      const labelFront = document.getElementById('labelFront');
      const labelBack = document.getElementById('labelBack');
      const allDots = document.querySelectorAll('.measure-dot');
      const allLines = document.querySelectorAll('.measure-line');

      function updateRotation(degrees) {
        if (mannequinInner) mannequinInner.style.transform = `rotateY(${degrees}deg)`;
        if (rotationSlider) {
          rotationSlider.value = Math.round(degrees);
          const percent = (degrees / 180) * 100;
          rotationSlider.style.background = `linear-gradient(to right, #0a0a0a 0%, #0a0a0a ${percent}%, #d4d4d4 ${percent}%, #d4d4d4 100%)`;
        }
        if (viewLabel) {
          if (degrees < 30) { viewLabel.innerHTML = '<strong>FRONT</strong>'; btnFront?.classList.add('active-toggle'); btnBack?.classList.remove('active-toggle'); }
          else if (degrees > 150) { viewLabel.innerHTML = '<strong>BACK</strong>'; btnBack?.classList.add('active-toggle'); btnFront?.classList.remove('active-toggle'); }
          else { viewLabel.innerHTML = '<strong>SIDE / ROTATING</strong>'; btnFront?.classList.remove('active-toggle'); btnBack?.classList.remove('active-toggle'); }
        }
      }

      rotationSlider?.addEventListener('input', function() { updateRotation(parseInt(this.value)); });
      btnFront?.addEventListener('click', () => updateRotation(0));
      btnBack?.addEventListener('click', () => updateRotation(180));
      labelFront?.addEventListener('click', () => updateRotation(0));
      labelBack?.addEventListener('click', () => updateRotation(180));

      function hideAllIndicators() {
        if (indicator) indicator.classList.remove('visible');
        allDots.forEach(d => d.classList.remove('active-dot'));
        allLines.forEach(l => l.classList.remove('active'));
      }

      allDots.forEach(dot => {
        dot.addEventListener('mouseenter', function() {
          hideAllIndicators();
          const measure = this.dataset.measure;
          allDots.forEach(d => { if (d.dataset.measure === measure) d.classList.add('active-dot'); });
          allLines.forEach(l => { if (l.dataset.measure === measure) l.classList.add('active'); });
          if (indicator) { indicator.textContent = measure.replace(/-/g, ' ').toUpperCase(); indicator.classList.add('visible'); }
        });
        dot.addEventListener('mouseleave', () => { setTimeout(() => { if (!document.querySelector('.measure-dot:hover') && !document.querySelector('.measure-line:hover')) hideAllIndicators(); }, 200); });
        dot.addEventListener('click', function() {
          const input = document.querySelector(`.measurement-input[data-measure="${this.dataset.measure}"]`);
          if (input) { input.focus(); input.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
        });
      });

      allLines.forEach(line => {
        line.addEventListener('mouseenter', function() {
          hideAllIndicators();
          const measure = this.dataset.measure;
          allDots.forEach(d => { if (d.dataset.measure === measure) d.classList.add('active-dot'); });
          allLines.forEach(l => { if (l.dataset.measure === measure) l.classList.add('active'); });
          if (indicator) { indicator.textContent = measure.replace(/-/g, ' ').toUpperCase(); indicator.classList.add('visible'); }
        });
        line.addEventListener('mouseleave', () => { setTimeout(() => { if (!document.querySelector('.measure-dot:hover') && !document.querySelector('.measure-line:hover')) hideAllIndicators(); }, 200); });
        line.addEventListener('click', function() {
          const input = document.querySelector(`.measurement-input[data-measure="${this.dataset.measure}"]`);
          if (input) { input.focus(); input.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
        });
      });

      mannequinContainer?.addEventListener('mouseleave', () => setTimeout(hideAllIndicators, 300));

      document.getElementById('registerBtn')?.addEventListener('click', () => {
        if (document.getElementById('phoneNumber').value.trim().length < 7) { alert('Please enter a valid phone number.'); return; }
        document.getElementById('regFeedback').classList.remove('hidden');
        document.querySelector('.measurement-input')?.scrollIntoView({ behavior: 'smooth' });
      });

      document.getElementById('saveMeasurementsBtn')?.addEventListener('click', () => {
        const inputs = document.querySelectorAll('.measurement-input');
        let ok = true;
        inputs.forEach(i => { if (!i.value) ok = false; });
        if (!ok) { alert('Please fill all measurement fields.'); return; }
        document.getElementById('measurementFeedback').classList.remove('hidden');
        setTimeout(() => document.getElementById('measurementFeedback').classList.add('hidden'), 4000);
      });

      updateRotation(0);
    })();
  </script>
