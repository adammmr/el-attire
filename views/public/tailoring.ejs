  <!-- ============ INDEPENDENT CART SCRIPT ============ -->
  <script>
    (function() {
      // This cart script is completely independent
      // It reads from localStorage and manages the cart drawer
      
      var cart = [];
      
      function loadCart() {
        try { cart = JSON.parse(localStorage.getItem('elattire_cart') || '[]'); } 
        catch(e) { cart = []; }
      }
      
      function saveCart() {
        localStorage.setItem('elattire_cart', JSON.stringify(cart));
      }
      
      function getTotalItems() {
        return cart.reduce(function(s, i) { return s + (i.qty || 1); }, 0);
      }
      
      function getSubtotal() {
        return cart.reduce(function(s, i) { return s + (i.price || 0) * (i.qty || 1); }, 0);
      }
      
      function formatNaira(n) {
        return '₦' + Math.round(n).toLocaleString();
      }
      
      function updateCartUI() {
        var total = getTotalItems();
        var badge = document.getElementById('cartBadge');
        var count = document.getElementById('drawerCount');
        var totalEl = document.getElementById('drawerTotal');
        var itemsEl = document.getElementById('drawerItems');
        
        if (badge) badge.textContent = total;
        if (count) count.textContent = total + ' item' + (total !== 1 ? 's' : '');
        if (totalEl) totalEl.textContent = formatNaira(getSubtotal());
        
        if (itemsEl) {
          if (cart.length === 0) {
            itemsEl.innerHTML = '<p class="text-neutral-400 text-[0.8rem] text-center py-16">Your bag is empty</p>';
          } else {
            itemsEl.innerHTML = cart.map(function(item, i) {
              var img = (item.images && item.images[0]) ? item.images[0] : 'https://placehold.co/56x56/e5e7eb/9ca3af';
              return '<div class="flex gap-3 items-start border-b border-gray-50 pb-3">' +
                '<img src="' + img + '" class="w-14 h-14 object-cover rounded" alt="' + (item.name || 'Item') + '" onerror="this.src=\'https://placehold.co/56x56/e5e7eb/9ca3af\'">' +
                '<div class="flex-1 min-w-0">' +
                  '<p class="text-[0.75rem] font-medium truncate">' + (item.name || 'Item') + '</p>' +
                  '<p class="text-[0.65rem] text-neutral-400">' + formatNaira(item.price || 0) + (item.unit ? '/' + item.unit : '') + (item.size ? ' · ' + item.size : '') + '</p>' +
                  '<div class="flex items-center gap-2 mt-1">' +
                    '<button class="border px-1.5 py-0.5 text-[0.6rem] rounded cart-qty-minus" data-index="' + i + '">−</button>' +
                    '<span class="text-[0.7rem] font-medium">' + (item.qty || 1) + '</span>' +
                    '<button class="border px-1.5 py-0.5 text-[0.6rem] rounded cart-qty-plus" data-index="' + i + '">+</button>' +
                  '</div>' +
                '</div>' +
                '<button class="text-neutral-400 hover:text-red-500 cart-remove" data-index="' + i + '"><i class="fas fa-trash text-[0.6rem]"></i></button>' +
              '</div>';
            }).join('');
            
            // Attach event listeners
            itemsEl.querySelectorAll('.cart-qty-plus').forEach(function(btn) {
              btn.addEventListener('click', function() {
                var idx = parseInt(this.dataset.index);
                if (cart[idx]) { cart[idx].qty = (cart[idx].qty || 1) + 1; saveCart(); updateCartUI(); }
              });
            });
            
            itemsEl.querySelectorAll('.cart-qty-minus').forEach(function(btn) {
              btn.addEventListener('click', function() {
                var idx = parseInt(this.dataset.index);
                if (cart[idx] && cart[idx].qty > 1) { cart[idx].qty--; }
                else { cart.splice(idx, 1); }
                saveCart(); updateCartUI();
              });
            });
            
            itemsEl.querySelectorAll('.cart-remove').forEach(function(btn) {
              btn.addEventListener('click', function() {
                var idx = parseInt(this.dataset.index);
                cart.splice(idx, 1);
                saveCart(); updateCartUI();
              });
            });
          }
        }
      }
      
      function openDrawer() {
        document.getElementById('cartDrawer').classList.add('open');
        document.getElementById('cartDrawerOverlay').classList.add('open');
        updateCartUI();
      }
      
      function closeDrawer() {
        document.getElementById('cartDrawer').classList.remove('open');
        document.getElementById('cartDrawerOverlay').classList.remove('open');
      }
      
      // Initialize
      loadCart();
      updateCartUI();
      
      // Event listeners
      document.getElementById('cartTriggerBtn').addEventListener('click', openDrawer);
      document.getElementById('closeDrawerBtn').addEventListener('click', closeDrawer);
      document.getElementById('cartDrawerOverlay').addEventListener('click', closeDrawer);
      
      console.log('🛒 Cart system initialized');
    })();
  </script>

