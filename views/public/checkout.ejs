

  <div class="toast" id="toast"></div>

  <!-- Invoice Overlay -->
  <div class="invoice-overlay" id="invoiceOverlay">
    <div class="invoice-paper" id="invoicePaper"></div>
  </div>



  <main class="max-w-6xl mx-auto px-4 md:px-6 py-6">
    <div class="mb-5">
      <h1 class="text-xl font-medium text-[#374151] mb-1">Cart & Checkout</h1>
      <div class="flex gap-4 mt-3 border-b border-gray-100">
        <button class="step-tab active-tab" data-step="cart">1. Cart</button>
        <button class="step-tab" data-step="checkout">2. Checkout</button>
        <button class="step-tab" data-step="complete">3. Complete</button>
      </div>
    </div>

    <div id="cartSection"></div>
    <div id="checkoutSection" class="hidden"></div>
    <div id="completeSection" class="hidden" style="min-height:50vh;"></div>
  </main>



  <!-- Independent Chat Widget -->
  <script>
    (function() {
      const widget = document.createElement('div');
      widget.className = 'chat-widget-overlay'; widget.id = 'chatWidget';
      widget.innerHTML = `<style>
        .chat-widget-overlay{position:fixed;bottom:24px;right:24px;width:350px;max-width:90vw;height:440px;max-height:65vh;background:white;border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,0.2);z-index:300;display:flex;flex-direction:column;transform:translateY(20px)scale(0.95);opacity:0;pointer-events:none;transition:all 0.25s cubic-bezier(0.23,1,0.32,1);border:1px solid rgba(0,0,0,0.08)}
        .chat-widget-overlay.open{transform:translateY(0)scale(1);opacity:1;pointer-events:all}
        .cw-h{padding:12px 14px;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between;border-radius:14px 14px 0 0;background:#fafafa}
        .cw-ag{display:flex;align-items:center;gap:8px}.cw-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;color:white;font-weight:600;font-size:0.65rem}
        .cw-on{display:flex;align-items:center;gap:4px;font-size:0.6rem;color:#10b981;font-weight:500}.cw-ond{width:5px;height:5px;border-radius:50%;background:#10b981}
        .cw-b{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;background:#fafafa}
        .cw-f{padding:10px 12px;border-top:1px solid #f3f4f6;display:flex;gap:6px;align-items:center}
        .cw-f input{flex:1;padding:8px 12px;border:1px solid #e5e7eb;border-radius:18px;font-size:0.75rem;outline:none;background:white;font-family:inherit}
        .cw-f input:focus{border-color:#9ca3af}.cw-s{width:34px;height:34px;border-radius:50%;border:none;background:#374151;color:white;cursor:pointer;font-size:0.75rem;transition:all 0.15s;flex-shrink:0}
        .cw-s:hover{background:#4b5563;transform:scale(1.05)}.cw-x{width:26px;height:26px;border-radius:50%;border:none;background:transparent;cursor:pointer;color:#9ca3af;font-size:0.9rem;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
        .cw-x:hover{background:#e5e7eb;color:#374151}.cw-bub{padding:8px 12px;border-radius:12px;font-size:0.75rem;line-height:1.5;max-width:85%;animation:cwIn 0.3s ease-out}
        @keyframes cwIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
        .cw-bub.in{background:white;color:#374151;align-self:flex-start;border-bottom-left-radius:4px;box-shadow:0 1px 2px rgba(0,0,0,0.04)}
        .cw-bub.out{background:#374151;color:white;align-self:flex-end;border-bottom-right-radius:4px}.cw-t{font-size:0.55rem;opacity:0.6;margin-top:3px;display:block}
        .cw-q{display:flex;flex-wrap:wrap;gap:4px;padding:0 12px 8px}.cw-q button{padding:5px 10px;border-radius:14px;border:1px solid #e5e7eb;background:white;font-size:0.65rem;cursor:pointer;transition:all 0.15s;color:#374151;font-family:inherit}
        .cw-q button:hover{background:#374151;color:white;border-color:#374151}
      </style>
      <div class="cw-h"><div class="cw-ag"><div class="cw-av">CS</div><div><p style="font-size:0.75rem;font-weight:500;color:#374151;margin:0">Customer Support</p><div class="cw-on"><span class="cw-ond"></span>Online</div></div></div><button class="cw-x" id="cwClose">✕</button></div>
      <div class="cw-b" id="cwMessages"><div class="cw-bub in">Hello! 👋 Need help with your order?<span class="cw-t">Just now</span></div></div>
      <div class="cw-q"><button onclick="window._cwSendQuick('Shipping cost')">🚚 Shipping</button><button onclick="window._cwSendQuick('Return policy')">↩️ Returns</button><button onclick="window._cwSendQuick('Payment methods')">💳 Payment</button></div>
      <div class="cw-f"><input type="text" placeholder="Type message..." id="cwInput" onkeypress="if(event.key==='Enter')window._cwSend()"><button class="cw-s" onclick="window._cwSend()"><i class="fas fa-paper-plane"></i></button></div>`;
      document.body.appendChild(widget);

      let isOpen = false;
      const replies = {'ship':'🚚 Free pickup at Lagos & Abuja studios. Home delivery: Lagos ₦5k (2-3 days), Abuja ₦10k (3-5 days).','return':'↩️ Uncut fabric returns within 7 days. Ready-made: 14 days unworn. Tailored garments adjustable within 14 days.','payment':'💳 We accept cards, bank transfer, and pay-on-delivery (Lagos & Abuja). All payments are secure.','default':'Thanks! An agent will respond shortly. For urgent help: +234 800 000 0000.'};
      function getReply(m){const x=m.toLowerCase();if(x.includes('ship')||x.includes('deliver'))return replies.ship;if(x.includes('return')||x.includes('refund'))return replies.return;if(x.includes('pay')||x.includes('card')||x.includes('transfer'))return replies.payment;return replies.default}
      function getTime(){return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:true})}
      function addMsg(text,type){const msgs=document.getElementById('cwMessages');const b=document.createElement('div');b.className='cw-bub '+(type==='sent'?'out':'in');b.innerHTML=text+'<span class="cw-t">'+getTime()+'</span>';msgs.appendChild(b);msgs.scrollTop=msgs.scrollHeight}
      window._cwSend=function(){const input=document.getElementById('cwInput');if(!input||!input.value.trim())return;addMsg(input.value.trim(),'sent');const msg=input.value.trim();input.value='';setTimeout(()=>addMsg(getReply(msg),'received'),700+Math.random()*1000)}
      window._cwSendQuick=function(text){const input=document.getElementById('cwInput');if(input)input.value=text;window._cwSend()}
      function open(){widget.classList.add('open');isOpen=true;setTimeout(()=>document.getElementById('cwInput')?.focus(),300)}
      function close(){widget.classList.remove('open');isOpen=false}
      function toggle(){isOpen?close():open()}
      document.getElementById('cwClose').addEventListener('click',close);
      document.addEventListener('keydown',function(e){if(e.key==='Escape'&&isOpen)close()});
      document.addEventListener('click',function(e){if(isOpen&&!widget.contains(e.target)&&e.target.id!=='supportHeaderToggle'&&!document.getElementById('supportHeaderToggle')?.contains(e.target))close()});
      document.getElementById('supportHeaderToggle').addEventListener('click',toggle);
    })();
  </script>

  <!-- Cart & Checkout Script - All functions exposed globally -->
  <script>
    // ============ STATE ============
    let cart = JSON.parse(localStorage.getItem('elattire_cart') || '[]');
    let currentStep = 'cart';
    let orderNumber = '';

    if (cart.length === 0) {
      cart = [
        { id:'fab-1', name:'Royal Blue Aso Oke', type:'fabric', price:120000, unit:'yard', qty:3, minQty:3, maxQty:45, images:['photos/fabrics/f1.jpg'], size:null },
        { id:'rm-1', name:'Embroidered Agbada Set', type:'clothing', price:380000, unit:'set', qty:1, minQty:1, maxQty:5, images:['photos/b1.jpg'], size:'L' },
        { id:'rm-2', name:'Senator White', type:'clothing', price:195000, unit:'piece', qty:1, minQty:1, maxQty:5, images:['photos/model_c1.jpg'], size:'M' }
      ];
      saveCart();
    }

    function saveCart() { localStorage.setItem('elattire_cart', JSON.stringify(cart)); }
    function getSubtotal() { return cart.reduce((s,i) => s + i.price * i.qty, 0); }
    function getShipping() { return getSubtotal() >= 200000 ? 0 : 5000; }
    function getTax() { return getSubtotal() * 0.075; }
    function getTotal() { return getSubtotal() + getShipping() + getTax(); }
    function formatNaira(n) { return '₦' + Math.round(n).toLocaleString(); }

    function showToast(msg, type) {
      type = type || '';
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = 'toast ' + type + ' show';
      setTimeout(function() { t.classList.remove('show'); }, 3000);
    }

    // ============ NAVIGATION (exposed globally) ============
    window.switchStep = function(step) {
      currentStep = step;
      var tabs = document.querySelectorAll('.step-tab');
      tabs.forEach(function(tab, i) {
        tab.classList.remove('active-tab', 'done');
        var steps = ['cart','checkout','complete'];
        if (steps[i] === step) tab.classList.add('active-tab');
        if (steps.indexOf(step) > i) tab.classList.add('done');
      });

      document.getElementById('cartSection').classList.toggle('hidden', step !== 'cart');
      document.getElementById('checkoutSection').classList.toggle('hidden', step !== 'checkout');
      document.getElementById('completeSection').classList.toggle('hidden', step !== 'complete');

      if (step === 'cart') renderCart();
      if (step === 'checkout') renderCheckout();
      if (step === 'complete') renderComplete();
    };

    // Step tab click handlers
    document.querySelectorAll('.step-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var step = this.dataset.step;
        if (step === 'cart' || (step === 'checkout' && cart.length > 0) || step === 'complete') {
          window.switchStep(step);
        }
      });
    });

    // ============ CART ============
    function renderCart() {
      var container = document.getElementById('cartSection');
      
      if (cart.length === 0) {
        container.innerHTML = '<div class="text-center py-16"><i class="fas fa-shopping-cart text-5xl text-neutral-300 mb-4 block"></i><h3 class="text-lg font-medium text-[#374151] mb-2">Your cart is empty</h3><p class="text-[0.8rem] text-neutral-400 mb-5">Add fabrics or clothing to get started</p><div class="flex gap-3 justify-center"><a href="fabrics.html" class="btn-primary px-5 py-2.5 text-[0.75rem] no-underline inline-block">Shop Fabrics</a><a href="collection.html" class="btn-outline px-5 py-2.5 text-[0.75rem] no-underline inline-block">Shop Clothing</a></div></div>';
        return;
      }

      var itemsHtml = '';
      cart.forEach(function(item, i) {
        itemsHtml += '<div class="flex gap-3 p-3 border border-gray-100 rounded-lg items-center bg-white">' +
          '<img src="' + item.images[0] + '" class="w-20 h-20 object-cover rounded-lg flex-shrink-0" alt="' + item.name + '" onerror="this.src=\'https://placehold.co/80x80/e5e7eb/9ca3af\'">' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2 mb-0.5"><span class="text-[0.6rem] uppercase tracking-wider text-neutral-400 bg-gray-50 px-1.5 py-0.5 rounded">' + (item.type === 'fabric' ? 'Fabric' : 'Clothing') + '</span>' + (item.size ? '<span class="text-[0.6rem] text-neutral-400">Size: ' + item.size + '</span>' : '') + '</div>' +
            '<h4 class="text-[0.8rem] font-medium text-[#374151]">' + item.name + '</h4>' +
            '<p class="text-[0.65rem] text-neutral-400">' + item.unit + ' · ₦' + item.price.toLocaleString() + '/' + item.unit + '</p>' +
            '<p class="font-semibold text-[0.78rem] mt-0.5">₦' + (item.price * item.qty).toLocaleString() + '</p>' +
          '</div>' +
          '<div class="flex items-center gap-2">' +
            '<button class="qty-btn" onclick="window._updateQty(' + i + ',-1)"' + (item.qty <= item.minQty ? ' disabled' : '') + '>−</button>' +
            '<span class="w-7 text-center font-medium text-[0.8rem]">' + item.qty + '</span>' +
            '<button class="qty-btn" onclick="window._updateQty(' + i + ',1)"' + (item.qty >= item.maxQty ? ' disabled' : '') + '>+</button>' +
          '</div>' +
          '<button class="text-neutral-400 hover:text-red-500 transition-colors ml-1" onclick="window._removeItem(' + i + ')" title="Remove"><i class="fas fa-trash text-[0.7rem]"></i></button>' +
        '</div>';
      });

      var summaryItems = '';
      cart.forEach(function(item) {
        summaryItems += '<div class="flex justify-between"><span class="text-neutral-400 truncate mr-2">' + item.name + ' ×' + item.qty + '</span><span>' + formatNaira(item.price * item.qty) + '</span></div>';
      });

      container.innerHTML = '<div class="grid lg:grid-cols-3 gap-5">' +
        '<div class="lg:col-span-2 space-y-2.5">' + itemsHtml + '</div>' +
        '<div class="glass-panel p-4 h-fit space-y-3">' +
          '<h3 class="text-[0.7rem] font-semibold uppercase tracking-wider text-neutral-400">Order Summary</h3>' +
          '<div class="text-[0.78rem] space-y-2"><p class="text-[0.65rem] text-neutral-400">' + cart.reduce(function(s,i){return s+i.qty},0) + ' item(s) in cart</p>' + summaryItems + '</div>' +
          '<div class="h-px bg-gray-100"></div>' +
          '<div class="space-y-1.5 text-[0.78rem]">' +
            '<div class="flex justify-between"><span class="text-neutral-400">Subtotal</span><span>' + formatNaira(getSubtotal()) + '</span></div>' +
            '<div class="flex justify-between"><span class="text-neutral-400">Shipping</span><span class="' + (getShipping()===0?'text-emerald-600':'') + '">' + (getShipping()===0?'Free':formatNaira(getShipping())) + '</span></div>' +
            '<div class="flex justify-between"><span class="text-neutral-400">Tax (7.5%)</span><span>' + formatNaira(getTax()) + '</span></div>' +
          '</div>' +
          '<div class="h-px bg-gray-100"></div>' +
          '<div class="flex justify-between font-semibold text-[0.85rem]"><span>Total</span><span>' + formatNaira(getTotal()) + '</span></div>' +
          (getShipping() > 0 ? '<p class="text-[0.62rem] text-amber-600">Add ' + formatNaira(200000 - getSubtotal()) + ' more for free shipping</p>' : '') +
          '<div class="flex gap-2"><input type="text" placeholder="Promo code" class="input-lux text-[0.72rem]" id="promoInput"><button class="btn-outline px-3 py-1.5 text-[0.68rem] whitespace-nowrap" onclick="window._applyPromo()">Apply</button></div>' +
          '<button class="btn-primary w-full py-2.5 text-[0.75rem]" onclick="window.switchStep(\'checkout\')">Proceed to Checkout</button>' +
          '<a href="fabrics.html" class="block text-center text-[0.7rem] text-neutral-400 hover:text-[#374151] transition-colors">← Continue Shopping</a>' +
        '</div></div>';
    }

    window._updateQty = function(index, delta) {
      var newQty = cart[index].qty + delta;
      if (newQty < cart[index].minQty) {
        if (confirm('Remove ' + cart[index].name + ' from cart?')) { cart.splice(index, 1); }
      } else if (newQty > cart[index].maxQty) {
        showToast('Maximum ' + cart[index].maxQty + ' ' + cart[index].unit + 's allowed', 'error');
      } else {
        cart[index].qty = newQty;
      }
      saveCart();
      renderCart();
    };

    window._removeItem = function(index) {
      var name = cart[index].name;
      cart.splice(index, 1);
      saveCart();
      renderCart();
      showToast(name + ' removed from cart');
    };

    window._applyPromo = function() {
      var code = document.getElementById('promoInput') ? document.getElementById('promoInput').value.trim() : '';
      if (code === 'ELATTIRE10') { showToast('10% discount applied!', 'success'); }
      else if (code) { showToast('Invalid promo code', 'error'); }
    };

    // ============ CHECKOUT ============
    function renderCheckout() {
      if (cart.length === 0) { window.switchStep('cart'); return; }

      var itemsList = '';
      cart.forEach(function(item) {
        itemsList += '<div class="flex justify-between"><span class="text-neutral-400 truncate mr-2">' + item.name + ' ×' + item.qty + '</span><span>' + formatNaira(item.price * item.qty) + '</span></div>';
      });

      document.getElementById('checkoutSection').innerHTML = '<div class="grid lg:grid-cols-3 gap-5">' +
        '<div class="lg:col-span-2 space-y-4">' +
          '<div class="glass-panel p-4">' +
            '<h3 class="text-[0.7rem] font-semibold uppercase tracking-wider text-neutral-400 mb-3">Shipping Information</h3>' +
            '<div class="grid grid-cols-2 gap-3">' +
              '<div><label class="text-[0.62rem] text-neutral-400">First Name <span class="text-red-400">*</span></label><input type="text" class="input-lux mt-0.5" id="chFirstName" value="Oluwaseun" required></div>' +
              '<div><label class="text-[0.62rem] text-neutral-400">Last Name <span class="text-red-400">*</span></label><input type="text" class="input-lux mt-0.5" id="chLastName" value="Adebayo" required></div>' +
            '</div>' +
            '<div class="mt-3"><label class="text-[0.62rem] text-neutral-400">Email <span class="text-red-400">*</span></label><input type="email" class="input-lux mt-0.5" id="chEmail" value="customer@email.com" required></div>' +
            '<div class="mt-3"><label class="text-[0.62rem] text-neutral-400">Phone <span class="text-red-400">*</span></label><input type="tel" class="input-lux mt-0.5" id="chPhone" value="+234 812 345 6789" required></div>' +
            '<div class="mt-3"><label class="text-[0.62rem] text-neutral-400">Address <span class="text-red-400">*</span></label><input type="text" class="input-lux mt-0.5" id="chAddress" value="15 Marina Road, Victoria Island" placeholder="Street address" required></div>' +
            '<div class="grid grid-cols-3 gap-3 mt-3">' +
              '<div><label class="text-[0.62rem] text-neutral-400">City</label><input type="text" class="input-lux mt-0.5" id="chCity" value="Lagos"></div>' +
              '<div><label class="text-[0.62rem] text-neutral-400">State</label><input type="text" class="input-lux mt-0.5" id="chState" value="Lagos"></div>' +
              '<div><label class="text-[0.62rem] text-neutral-400">ZIP</label><input type="text" class="input-lux mt-0.5" id="chZip" value="101241"></div>' +
            '</div>' +
            '<div class="mt-3"><label class="text-[0.62rem] text-neutral-400">Delivery Method</label><select class="input-lux mt-0.5" id="chDelivery"><option value="0">Store Pickup (Free)</option><option value="5000">Home Delivery · Lagos (₦5,000)</option><option value="10000">Home Delivery · Abuja (₦10,000)</option></select></div>' +
            '<div class="mt-3"><label class="text-[0.62rem] text-neutral-400">Order Notes</label><textarea class="input-lux mt-0.5" rows="2" id="chNotes" placeholder="Special instructions..."></textarea></div>' +
          '</div>' +
          '<div class="glass-panel p-4">' +
            '<h3 class="text-[0.7rem] font-semibold uppercase tracking-wider text-neutral-400 mb-3">Payment Method</h3>' +
            '<div class="space-y-2" id="paymentOptions">' +
              '<label class="payment-option selected" data-payment="card"><input type="radio" name="payment" value="card" checked> <i class="far fa-credit-card text-[#374151]"></i> <span>Credit / Debit Card</span></label>' +
              '<label class="payment-option" data-payment="transfer"><input type="radio" name="payment" value="transfer"> <i class="fas fa-university text-[#374151]"></i> <span>Bank Transfer</span></label>' +
              '<label class="payment-option" data-payment="pod"><input type="radio" name="payment" value="pod"> <i class="fas fa-money-bill-wave text-[#374151]"></i> <span>Pay on Delivery</span></label>' +
            '</div>' +
            '<div id="cardFields" class="mt-4 space-y-3">' +
              '<div><label class="text-[0.62rem] text-neutral-400">Card Number</label><input type="text" class="input-lux mt-0.5" id="chCardNumber" placeholder="1234 5678 9012 3456"></div>' +
              '<div class="grid grid-cols-2 gap-3"><div><label class="text-[0.62rem] text-neutral-400">Expiry</label><input type="text" class="input-lux mt-0.5" id="chExpiry" placeholder="MM/YY"></div><div><label class="text-[0.62rem] text-neutral-400">CVV</label><input type="text" class="input-lux mt-0.5" id="chCvv" placeholder="123"></div></div>' +
            '</div>' +
          '</div>' +
        '</div>' +
        '<div class="glass-panel p-4 h-fit space-y-3">' +
          '<h3 class="text-[0.7rem] font-semibold uppercase tracking-wider text-neutral-400">Order Summary</h3>' +
          '<div class="text-[0.75rem] space-y-1.5">' + itemsList + '</div>' +
          '<div class="h-px bg-gray-100"></div>' +
          '<div class="space-y-1.5 text-[0.78rem]">' +
            '<div class="flex justify-between"><span class="text-neutral-400">Subtotal</span><span id="chkSubtotal">' + formatNaira(getSubtotal()) + '</span></div>' +
            '<div class="flex justify-between"><span class="text-neutral-400">Shipping</span><span id="chkShipping">' + (getShipping()===0?'Free':formatNaira(getShipping())) + '</span></div>' +
            '<div class="flex justify-between"><span class="text-neutral-400">Tax (7.5%)</span><span id="chkTax">' + formatNaira(getTax()) + '</span></div>' +
          '</div>' +
          '<div class="h-px bg-gray-100"></div>' +
          '<div class="flex justify-between font-semibold text-[0.85rem]"><span>Total</span><span id="chkTotal">' + formatNaira(getTotal()) + '</span></div>' +
          '<button class="btn-primary w-full py-2.5 text-[0.75rem]" id="placeOrderBtn">Place Order</button>' +
          '<button class="btn-outline w-full py-2 text-[0.7rem]" id="previewInvoiceBtn"><i class="fas fa-file-invoice mr-1.5 text-[0.55rem]"></i>Preview Invoice</button>' +
          '<button class="text-[0.7rem] text-neutral-400 hover:text-[#374151] transition-colors w-full text-center bg-transparent border-none cursor-pointer" onclick="window.switchStep(\'cart\')" style="font-family:inherit;">← Back to Cart</button>' +
        '</div></div>';

      // Payment switching
      document.querySelectorAll('.payment-option').forEach(function(opt) {
        opt.addEventListener('click', function() {
          document.querySelectorAll('.payment-option').forEach(function(o) { o.classList.remove('selected'); });
          this.classList.add('selected');
          this.querySelector('input[type="radio"]').checked = true;
          document.getElementById('cardFields').style.display = this.dataset.payment === 'card' ? 'block' : 'none';
        });
      });

      // Delivery change
      document.getElementById('chDelivery').addEventListener('change', function() {
        var shipping = parseInt(this.value);
        var subtotal = getSubtotal();
        var tax = subtotal * 0.075;
        document.getElementById('chkShipping').textContent = shipping === 0 ? 'Free' : formatNaira(shipping);
        document.getElementById('chkTax').textContent = formatNaira(tax);
        document.getElementById('chkTotal').textContent = formatNaira(subtotal + shipping + tax);
      });

      document.getElementById('previewInvoiceBtn').addEventListener('click', showInvoice);
      document.getElementById('placeOrderBtn').addEventListener('click', placeOrder);
    }

    function placeOrder() {
      var fields = ['chFirstName','chLastName','chEmail','chPhone','chAddress'];
      var valid = true;
      fields.forEach(function(id) {
        var el = document.getElementById(id);
        if (!el.value.trim()) { el.classList.add('error'); valid = false; }
        else { el.classList.remove('error'); }
      });
      if (!valid) { showToast('Please fill in all required fields', 'error'); return; }

      orderNumber = 'INV-' + new Date().toISOString().slice(0,10).replace(/-/g,'') + '-' + Math.random().toString(36).substr(2,4).toUpperCase();
      
      var orders = JSON.parse(localStorage.getItem('elattire_orders') || '[]');
      orders.unshift({
        id: orderNumber, date: new Date().toISOString(), items: JSON.parse(JSON.stringify(cart)),
        subtotal: getSubtotal(), shipping: getShipping(), tax: getTax(), total: getTotal(),
        shippingAddress: {
          name: document.getElementById('chFirstName').value + ' ' + document.getElementById('chLastName').value,
          email: document.getElementById('chEmail').value, phone: document.getElementById('chPhone').value,
          address: document.getElementById('chAddress').value, city: document.getElementById('chCity').value,
          state: document.getElementById('chState').value, zip: document.getElementById('chZip').value
        },
        payment: document.querySelector('input[name="payment"]:checked').value,
        delivery: document.getElementById('chDelivery').value,
        notes: document.getElementById('chNotes').value, status: 'processing'
      });
      localStorage.setItem('elattire_orders', JSON.stringify(orders));

      cart = []; saveCart();
      window.switchStep('complete');
      showToast('Order placed successfully!', 'success');
    }

    // ============ COMPLETE ============
    function renderComplete() {
      document.getElementById('completeSection').innerHTML = '<div class="text-center py-10">' +
        '<div class="w-16 h-16 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-5"><i class="fas fa-check text-emerald-600 text-2xl"></i></div>' +
        '<h2 class="text-xl font-medium text-[#374151] mb-2">Order Confirmed!</h2>' +
        '<p class="text-[0.8rem] font-mono font-semibold text-[#374151] mb-1">' + (orderNumber || '#INV-2026-0704-001') + '</p>' +
        '<p class="text-[0.72rem] text-neutral-400 mb-6">Confirmation sent to your email</p>' +
        '<div class="flex gap-3 justify-center">' +
          '<button class="btn-primary px-5 py-2.5 text-[0.72rem]" onclick="window._showInvoice()"><i class="fas fa-file-invoice mr-1.5 text-[0.6rem]"></i>View Invoice</button>' +
          '<a href="collection.html" class="btn-outline px-5 py-2.5 text-[0.72rem] no-underline inline-block">Continue Shopping</a>' +
        '</div></div>';
    }

    // ============ INVOICE ============
    function showInvoice() {
      var shipping = parseInt(document.getElementById('chDelivery') ? document.getElementById('chDelivery').value : 0);
      var total = getSubtotal() + shipping + getTax();
      var paymentLabel = 'Credit/Debit Card';
      var paymentRadio = document.querySelector('input[name="payment"]:checked');
      if (paymentRadio) {
        if (paymentRadio.value === 'transfer') paymentLabel = 'Bank Transfer';
        if (paymentRadio.value === 'pod') paymentLabel = 'Pay on Delivery';
      }

      var itemsRows = '';
      if (cart.length) {
        cart.forEach(function(item) {
          itemsRows += '<tr><td>' + item.name + ' <span class="text-[0.55rem] text-neutral-400">' + item.unit + (item.size?' · '+item.size:'') + '</span></td><td class="text-center">' + item.qty + '</td><td class="text-right">' + formatNaira(item.price) + '</td><td class="text-right">' + formatNaira(item.price*item.qty) + '</td></tr>';
        });
      } else {
        itemsRows = '<tr><td>Royal Blue Aso Oke</td><td class="text-center">3</td><td class="text-right">₦120,000</td><td class="text-right">₦360,000</td></tr><tr><td>Agbada Set</td><td class="text-center">1</td><td class="text-right">₦380,000</td><td class="text-right">₦380,000</td></tr><tr><td>Senator White</td><td class="text-center">1</td><td class="text-right">₦195,000</td><td class="text-right">₦195,000</td></tr>';
      }

      document.getElementById('invoicePaper').innerHTML = '<div class="invoice-watermark">EL-ATTIRE</div>' +
        '<div class="flex justify-between items-start mb-5"><div><h2>EL-ATTIRE</h2><p class="text-[0.6rem] text-neutral-400 mt-0.5">Bespoke Nigerian Tailoring</p><p class="text-[0.55rem] text-neutral-400">Lagos · Abuja · Milano</p></div><div class="text-right"><h2 class="text-sm font-bold tracking-widest">INVOICE</h2><p class="text-[0.65rem] mono mt-1 font-semibold">' + (orderNumber || 'INV-2026-0704-001') + '</p><p class="text-[0.55rem] text-neutral-400">' + new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) + '</p></div></div>' +
        '<div class="inv-line mb-4"></div>' +
        '<div class="grid grid-cols-2 gap-5 mb-4"><div><p class="text-[0.55rem] font-semibold uppercase tracking-widest text-neutral-400 mb-1.5">Bill To</p><p class="font-semibold text-[0.7rem]">' + (document.getElementById('chFirstName')?document.getElementById('chFirstName').value:'Oluwaseun') + ' ' + (document.getElementById('chLastName')?document.getElementById('chLastName').value:'Adebayo') + '</p></div><div><p class="text-[0.55rem] font-semibold uppercase tracking-widest text-neutral-400 mb-1.5">Shipping To</p><p class="font-semibold text-[0.7rem]">' + (document.getElementById('chAddress')?document.getElementById('chAddress').value:'15 Marina Road, VI') + '</p></div></div>' +
        '<table class="mb-4"><thead><tr class="inv-line"><th>Item</th><th class="text-center">Qty</th><th class="text-right">Price</th><th class="text-right">Total</th></tr></thead><tbody>' + itemsRows + '</tbody></table>' +
        '<div class="inv-dashed mb-3"></div>' +
        '<div class="flex justify-end"><div class="w-48 space-y-1 text-[0.65rem]"><div class="flex justify-between"><span class="text-neutral-400">Subtotal</span><span>' + formatNaira(getSubtotal()) + '</span></div><div class="flex justify-between"><span class="text-neutral-400">Shipping</span><span>' + (shipping===0?'Free':formatNaira(shipping)) + '</span></div><div class="flex justify-between"><span class="text-neutral-400">Tax (7.5%)</span><span>' + formatNaira(getTax()) + '</span></div><div class="inv-line my-1"></div><div class="flex justify-between font-bold text-[0.8rem]"><span>TOTAL</span><span>' + formatNaira(total) + '</span></div></div></div>' +
        '<div class="mt-5 pt-3 border-t text-[0.55rem] text-neutral-400"><p>Payment: ' + paymentLabel + '</p><p class="mt-0.5">Thank you for choosing EL-ATTIRE.</p></div>' +
        '<div class="mt-5 text-center no-print"><button class="btn-primary px-4 py-2 text-[0.65rem] mr-2" onclick="window.print()"><i class="fas fa-print mr-1"></i>Print</button><button class="btn-outline px-4 py-2 text-[0.65rem]" onclick="document.getElementById(\'invoiceOverlay\').classList.remove(\'open\')">Close</button></div>';
      
      document.getElementById('invoiceOverlay').classList.add('open');
    }

    window._showInvoice = showInvoice;

    // Invoice overlay close
    document.getElementById('invoiceOverlay').addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });

    // ============ INIT ============
    renderCart();
  </script>
