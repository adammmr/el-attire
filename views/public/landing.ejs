                    "</style>" +
                    '<div class="cw-h"><div class="cw-ag"><div class="cw-av">CS</div><div><p style="font-size:0.75rem;font-weight:500;color:#374151;margin:0">Customer Support</p><div class="cw-on"><span class="cw-ond"></span>Online</div></div></div><button class="cw-x" id="cwCloseBtn">✕</button></div>' +
                    '<div class="cw-b" id="cwMessages"><div class="cw-bub in">Hello! 👋 Welcome to EL-ATTIRE. How can we help?<span class="cw-t">Just now</span></div></div>' +
                    '<div class="cw-q"><button id="cwQuickFitting">📅 Fitting</button><button id="cwQuickFabric">🧵 Fabrics</button><button id="cwQuickPrice">💰 Pricing</button></div>' +
                    '<div class="cw-f"><input type="text" placeholder="Type message..." id="cwInput"><button class="cw-s" id="cwSendBtn"><i class="fas fa-paper-plane"></i></button></div>';
                document.body.appendChild(widget);

                var isOpen = false;
                var replies = {
                    fitting:
                        "📅 Book a fitting at our Lagos or Abuja studio. Mon-Fri 9AM-5PM, Sat 9AM-2PM. Virtual consultations also available!",
                    fabric: "🧵 We stock Aso Oke, Damask, Silk, Brocade & Cotton. Visit our Fabrics page to browse. Prices from ₦45k-230k/yard.",
                    price: "💰 Tailoring: ₦95k-495k/garment. Fabrics: ₦45k-230k/yard. Ready-made: ₦165k-450k. Free shipping over ₦200k.",
                    default: "Thanks! A specialist will respond shortly. For immediate assistance: +234 800 000 0000.",
                };
                function getReply(m) {
                    var x = m.toLowerCase();
                    if (x.indexOf("fitting") > -1 || x.indexOf("book") > -1) return replies.fitting;
                    if (x.indexOf("fabric") > -1 || x.indexOf("material") > -1) return replies.fabric;
                    if (x.indexOf("price") > -1 || x.indexOf("cost") > -1) return replies.price;
                    return replies.default;
                }
                function getTime() {
                    return new Date().toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: true });
                }
                function addMsg(text, type) {
                    var msgs = document.getElementById("cwMessages");
                    var b = document.createElement("div");
                    b.className = "cw-bub " + (type === "sent" ? "out" : "in");
                    b.innerHTML = text + '<span class="cw-t">' + getTime() + "</span>";
                    msgs.appendChild(b);
                    msgs.scrollTop = msgs.scrollHeight;
                }
                function sendMsg() {
                    var input = document.getElementById("cwInput");
                    if (!input || !input.value.trim()) return;
                    var msg = input.value.trim();
                    addMsg(msg, "sent");
                    input.value = "";
                    setTimeout(
                        function () {
                            addMsg(getReply(msg), "received");
                        },
                        700 + Math.random() * 1000
                    );
                }
                function sendQuick(text) {
                    var input = document.getElementById("cwInput");
                    if (input) input.value = text;
                    sendMsg();
                }
                function open() {
                    widget.classList.add("open");
                    isOpen = true;
                    setTimeout(function () {
                        var inp = document.getElementById("cwInput");
                        if (inp) inp.focus();
                    }, 300);
                }
                function close() {
                    widget.classList.remove("open");
                    isOpen = false;
                }
                function toggle() {
                    isOpen ? close() : open();
                }
                document.getElementById("cwCloseBtn").addEventListener("click", close);
                document.getElementById("cwSendBtn").addEventListener("click", sendMsg);
                document.getElementById("cwInput").addEventListener("keypress", function (e) {
                    if (e.key === "Enter") sendMsg();
                });
                document.getElementById("cwQuickFitting").addEventListener("click", function () {
                    sendQuick("Book fitting");
                });
                document.getElementById("cwQuickFabric").addEventListener("click", function () {
                    sendQuick("Fabric info");
                });
                document.getElementById("cwQuickPrice").addEventListener("click", function () {
                    sendQuick("Pricing");
                });
                document.addEventListener("keydown", function (e) {
                    if (e.key === "Escape" && isOpen) close();
                });
                document.addEventListener("click", function (e) {
                    if (
                        isOpen &&
                        !widget.contains(e.target) &&
                        e.target.id !== "supportHeaderToggle" &&
                        !document.getElementById("supportHeaderToggle").contains(e.target)
                    )
                        close();
                });
                document.getElementById("supportHeaderToggle").addEventListener("click", toggle);
            })();
        </script>

        <!-- Hero Carousel Script -->
        <script>
            (function () {
                var slides = document.querySelectorAll(".hero-slide");
                var dots = document.querySelectorAll(".hero-dot");
                var currentSlide = 0;
                var totalSlides = slides.length;
                var autoPlayInterval;

                function showSlide(index) {
                    slides.forEach(function (s) {
                        s.classList.remove("active");
                    });
                    dots.forEach(function (d) {
                        d.classList.remove("active-dot");
                    });
                    if (slides[index]) slides[index].classList.add("active");
                    if (dots[index]) dots[index].classList.add("active-dot");
                    currentSlide = index;
                }

                function nextSlide() {
                    showSlide((currentSlide + 1) % totalSlides);
                }
                function prevSlide() {
                    showSlide((currentSlide - 1 + totalSlides) % totalSlides);
                }

                document.getElementById("heroNext").addEventListener("click", function () {
                    nextSlide();
                    resetAutoPlay();
                });
                document.getElementById("heroPrev").addEventListener("click", function () {
                    prevSlide();
                    resetAutoPlay();
                });

                dots.forEach(function (dot) {
                    dot.addEventListener("click", function () {
                        showSlide(parseInt(this.dataset.index));
                        resetAutoPlay();
                    });
                });

                function startAutoPlay() {
                    autoPlayInterval = setInterval(nextSlide, 5000);
                }
                function resetAutoPlay() {
                    clearInterval(autoPlayInterval);
                    startAutoPlay();
                }

                startAutoPlay();
            })();
        </script>
    