  <!-- Independent Chat Widget -->
  <script>
    (function() {
      var widget = document.createElement('div');
      widget.className = 'chat-widget-overlay'; widget.id = 'chatWidget';
      widget.innerHTML = '<style>' +
        '.chat-widget-overlay{position:fixed;bottom:24px;right:24px;width:350px;max-width:90vw;height:440px;max-height:65vh;background:white;border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,0.2);z-index:300;display:flex;flex-direction:column;transform:translateY(20px)scale(0.95);opacity:0;pointer-events:none;transition:all 0.25s cubic-bezier(0.23,1,0.32,1);border:1px solid rgba(0,0,0,0.08)}' +
        '.chat-widget-overlay.open{transform:translateY(0)scale(1);opacity:1;pointer-events:all}' +
        '.cw-h{padding:12px 14px;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between;border-radius:14px 14px 0 0;background:#fafafa}' +
        '.cw-ag{display:flex;align-items:center;gap:8px}.cw-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;color:white;font-weight:600;font-size:0.65rem}' +
        '.cw-on{display:flex;align-items:center;gap:4px;font-size:0.6rem;color:#10b981;font-weight:500}.cw-ond{width:5px;height:5px;border-radius:50%;background:#10b981}' +
        '.cw-b{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;background:#fafafa}' +
        '.cw-f{padding:10px 12px;border-top:1px solid #f3f4f6;display:flex;gap:6px;align-items:center}' +
        '.cw-f input{flex:1;padding:8px 12px;border:1px solid #e5e7eb;border-radius:18px;font-size:0.75rem;outline:none;background:white;font-family:inherit}' +
        '.cw-s{width:34px;height:34px;border-radius:50%;border:none;background:#374151;color:white;cursor:pointer;font-size:0.75rem;transition:all 0.15s;flex-shrink:0}' +
        '.cw-s:hover{background:#4b5563;transform:scale(1.05)}.cw-x{width:26px;height:26px;border-radius:50%;border:none;background:transparent;cursor:pointer;color:#9ca3af;font-size:0.9rem;display:flex;align-items:center;justify-content:center;transition:all 0.15s}' +
        '.cw-x:hover{background:#e5e7eb;color:#374151}.cw-bub{padding:8px 12px;border-radius:12px;font-size:0.75rem;line-height:1.5;max-width:85%;animation:cwIn 0.3s ease-out}' +
        '@keyframes cwIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}' +
        '.cw-bub.in{background:white;color:#374151;align-self:flex-start;border-bottom-left-radius:4px}' +
        '.cw-bub.out{background:#374151;color:white;align-self:flex-end;border-bottom-right-radius:4px}' +
        '.cw-t{font-size:0.55rem;opacity:0.6;margin-top:3px;display:block}' +
        '.cw-q{display:flex;flex-wrap:wrap;gap:4px;padding:0 12px 8px}' +
        '.cw-q button{padding:5px 10px;border-radius:14px;border:1px solid #e5e7eb;background:white;font-size:0.65rem;cursor:pointer;transition:all 0.15s;color:#374151;font-family:inherit}' +
        '.cw-q button:hover{background:#374151;color:white;border-color:#374151}' +
      '</style>' +
      '<div class="cw-h"><div class="cw-ag"><div class="cw-av">CS</div><div><p style="font-size:0.75rem;font-weight:500;color:#374151;margin:0">Customer Support</p><div class="cw-on"><span class="cw-ond"></span>Online</div></div></div><button class="cw-x" id="cwCloseBtn">✕</button></div>' +
      '<div class="cw-b" id="cwMessages"><div class="cw-bub in">Hello! 👋 Love a look? Let us help you get it.<span class="cw-t">Just now</span></div></div>' +
      '<div class="cw-q"><button id="cwQuickLook">👔 This Look</button><button id="cwQuickCustom">✂️ Custom</button><button id="cwQuickFitting">📅 Fitting</button></div>' +
      '<div class="cw-f"><input type="text" placeholder="Type message..." id="cwInput"><button class="cw-s" id="cwSendBtn"><i class="fas fa-paper-plane"></i></button></div>';
      document.body.appendChild(widget);

      var isOpen = false;
      var replies = {'look':'👔 All our lookbook styles are available made-to-order. Visit the Shop page or book a fitting to get the exact look in your size.','custom':'✂️ We can customize any look — change fabric, color, or details. Book a consultation with our stylists.','fitting':'📅 Book a fitting at our Lagos or Abuja studio. Mon-Fri 9AM-5PM, Sat 9AM-2PM. Virtual available.','default':'Thanks! A style consultant will respond shortly. For immediate help: +234 800 000 0000.'};
      function getReply(m){var x=m.toLowerCase();if(x.indexOf('look')>-1||x.indexOf('style')>-1)return replies.look;if(x.indexOf('custom')>-1||x.indexOf('change')>-1)return replies.custom;if(x.indexOf('fitting')>-1||x.indexOf('book')>-1)return replies.fitting;return replies.default}
      function getTime(){return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:true})}
      function addMsg(text,type){var msgs=document.getElementById('cwMessages');var b=document.createElement('div');b.className='cw-bub '+(type==='sent'?'out':'in');b.innerHTML=text+'<span class="cw-t">'+getTime()+'</span>';msgs.appendChild(b);msgs.scrollTop=msgs.scrollHeight}
      function sendMsg(){var input=document.getElementById('cwInput');if(!input||!input.value.trim())return;var msg=input.value.trim();addMsg(msg,'sent');input.value='';setTimeout(function(){addMsg(getReply(msg),'received');},700+Math.random()*1000)}
      function sendQuick(text){var input=document.getElementById('cwInput');if(input)input.value=text;sendMsg()}
      function open(){widget.classList.add('open');isOpen=true;setTimeout(function(){var inp=document.getElementById('cwInput');if(inp)inp.focus();},300)}
      function close(){widget.classList.remove('open');isOpen=false}
      function toggle(){isOpen?close():open()}
      document.getElementById('cwCloseBtn').addEventListener('click',close);
      document.getElementById('cwSendBtn').addEventListener('click',sendMsg);
      document.getElementById('cwInput').addEventListener('keypress',function(e){if(e.key==='Enter')sendMsg()});
      document.getElementById('cwQuickLook').addEventListener('click',function(){sendQuick('This look')});
      document.getElementById('cwQuickCustom').addEventListener('click',function(){sendQuick('Custom order')});
      document.getElementById('cwQuickFitting').addEventListener('click',function(){sendQuick('Book fitting')});
      document.addEventListener('keydown',function(e){if(e.key==='Escape'&&isOpen)close()});
      document.addEventListener('click',function(e){if(isOpen&&!widget.contains(e.target)&&e.target.id!=='supportHeaderToggle'&&!document.getElementById('supportHeaderToggle').contains(e.target))close()});
      document.getElementById('supportHeaderToggle').addEventListener('click',toggle);
    })();
  </script>

  <!-- Lookbook Script -->
  <script>
    (function() {
      var looks = [
        { id:'royal-blue', name:'Royal Blue Kaftan', style:'Flowing ankle-length Kaftan with intricate chest embroidery and side slits. A modern interpretation of classic Nigerian elegance, designed to command attention at any formal gathering.', fabric:'Premium Aso Oke with metallic thread accents. Medium weight, breathable, with subtle sheen under light. Handwoven by master artisans in Oyo State.', occasion:'Wedding', colors:['#1a3a5c','#c9a84c','#f5f5f0'], price:245000, type:'Kaftan', images:['photos/tailoring/style_1a.jpg','photos/tailoring/style_1b.jpg','photos/a1.jpg','photos/a2.jpg'] },
        { id:'gold-agbada', name:'Gold Agbada Ensemble', style:'Full three-piece Agbada set with flowing outer robe, fitted inner wear, and matching trousers. The gold embroidery traces traditional Yoruba motifs across the chest and back.', fabric:'Handwoven Aso Oke with real gold thread embroidery. Heavyweight, regal drape that commands presence. Each set requires over 40 hours of handwork.', occasion:'Wedding', colors:['#c9a84c','#8b6914','#fff8dc'], price:450000, type:'Agbada', images:['photos/tailoring/agbada_a1.jpg','photos/tailoring/agbada_a2.jpg','photos/tailoring/agbada1.jpg','photos/tailoring/agbada1b.jpg'] },
        { id:'white-senator', name:'Senator White', style:'Clean, minimalist Senator style with mandarin collar and subtle tonal embroidery. The epitome of understated sophistication for the modern professional.', fabric:'Premium cotton lawn with silk lining. Lightweight and breathable, perfect for all-day wear in warm climates. Italian-inspired tailoring with Nigerian soul.', occasion:'Corporate', colors:['#ffffff','#f0f0f0','#e8e8e8'], price:195000, type:'Senator', images:['photos/tailoring/style2.jpg','photos/tailoring/style2b.jpg','photos/model_c1.jpg','photos/model_c2.jpg'] },
        { id:'midnight-brocade', name:'Midnight Brocade Kaftan', style:'Slim-fit Kaftan with mandarin collar and hidden placket. Modern silhouette meets traditional fabric for a look that bridges generations.', fabric:'Italian brocade with subtle floral pattern. Medium-heavy weight with excellent drape. The midnight blue shifts subtly under different lighting.', occasion:'Events', colors:['#0a0a2e','#1a1a4e','#c0c0d0'], price:275000, type:'Kaftan', images:['photos/model_d1.jpg','photos/model_d3.jpg','photos/a3.jpg','photos/b1.jpg'] },
        { id:'emerald-agbada', name:'Emerald Agbada', style:'Statement Agbada in rich emerald with contrasting gold embroidery. A bold choice for the man who leads with confidence and style.', fabric:'Silk-blend damask with metallic embroidery. Luxurious weight and movement. The emerald tone is inspired by the lush landscapes of the Obudu Plateau.', occasion:'Events', colors:['#0a5c3a','#c9a84c','#1a3a2a'], price:420000, type:'Agbada', images:['photos/tailoring/agbada1.jpg','photos/tailoring/agbada1b.jpg','photos/tailoring/agbada_a1.jpg','photos/b2.jpg'] },
        { id:'navy-casual', name:'Navy Casual Kaftan', style:'Relaxed-fit everyday Kaftan with minimal detailing. Comfortable yet polished — perfect for weekend gatherings and casual celebrations.', fabric:'Lightweight cotton blend. Soft, breathable, perfect for daily wear. Easy care with machine washability while maintaining its crisp appearance.', occasion:'Casual', colors:['#1a2a4a','#2a3a5a','#d0d5e0'], price:165000, type:'Kaftan', images:['photos/model_c1.jpg','photos/a1.jpg','photos/model_d1.jpg','photos/tailoring/style_1a.jpg'] }
      ];

      var currentPage = 0, looksPerPage = 4, totalPages = Math.ceil(looks.length / looksPerPage);
      var cfCurrentIndex = 0, cfLookData = null;

      function openCenterfold(lookId) {
        cfLookData = looks.find(function(l) { return l.id === lookId; });
        if (!cfLookData) return;
        cfCurrentIndex = 0;
        renderCenterfoldImage();
        renderCenterfoldSidebar();
        document.getElementById('centerfoldOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeCenterfold() {
        document.getElementById('centerfoldOverlay').classList.remove('open');
        document.body.style.overflow = '';
        cfLookData = null;
      }

      function renderCenterfoldImage() {
        if (!cfLookData) return;
        var scroll = document.getElementById('centerfoldScroll');
        scroll.innerHTML = '<img src="' + cfLookData.images[cfCurrentIndex] + '" class="centerfold-full-image" alt="' + cfLookData.name + '" onerror="this.src=\'https://placehold.co/800x1200/e5e7eb/9ca3af?text=' + encodeURIComponent(cfLookData.name) + '\'">';
        scroll.scrollTop = 0;

        var dotsContainer = document.getElementById('cfDots');
        dotsContainer.innerHTML = cfLookData.images.map(function(_, i) {
          return '<div class="centerfold-dot ' + (i === cfCurrentIndex ? 'active-dot' : '') + '" data-index="' + i + '"></div>';
        }).join('');
        document.getElementById('cfCounter').textContent = (cfCurrentIndex + 1) + ' / ' + cfLookData.images.length;

        dotsContainer.querySelectorAll('.centerfold-dot').forEach(function(dot) {
          dot.addEventListener('click', function() { cfCurrentIndex = parseInt(this.dataset.index); updateCenterfold(); });
        });
      }

      function updateCenterfold() {
        if (!cfLookData) return;
        var scroll = document.getElementById('centerfoldScroll');
        scroll.innerHTML = '<img src="' + cfLookData.images[cfCurrentIndex] + '" class="centerfold-full-image" alt="' + cfLookData.name + '" onerror="this.src=\'https://placehold.co/800x1200/e5e7eb/9ca3af?text=' + encodeURIComponent(cfLookData.name) + '\'">';
        scroll.scrollTop = 0;
        document.querySelectorAll('.centerfold-dot').forEach(function(d, i) { d.classList.toggle('active-dot', i === cfCurrentIndex); });
        document.getElementById('cfCounter').textContent = (cfCurrentIndex + 1) + ' / ' + cfLookData.images.length;
        renderCenterfoldSidebar();
      }

      function renderCenterfoldSidebar() {
        var sidebar = document.getElementById('cfSidebarContent');
        if (!cfLookData) return;
        sidebar.innerHTML = 
          '<span class="text-[0.6rem] uppercase tracking-[0.15em] text-neutral-400">' + cfLookData.occasion + ' · ' + cfLookData.type + '</span>' +
          '<h2 class="text-2xl font-light section-title text-[#374151] mt-1.5 mb-3">' + cfLookData.name + '</h2>' +
          '<div class="space-y-3 text-[0.78rem] flex-1">' +
            '<div><span class="font-medium uppercase text-[0.6rem] tracking-wider text-neutral-400">Article</span><p class="mt-1 text-neutral-500 leading-relaxed">' + cfLookData.style + '</p></div>' +
            '<div><span class="font-medium uppercase text-[0.6rem] tracking-wider text-neutral-400">Fabric & Craft</span><p class="mt-1 text-neutral-500 leading-relaxed">' + cfLookData.fabric + '</p></div>' +
            '<div class="flex gap-1.5">' + cfLookData.colors.map(function(c) { return '<span class="swatch" style="background:' + c + ';"></span>'; }).join('') + '</div>' +
            '<p class="text-xl font-semibold text-[#374151]">₦' + cfLookData.price.toLocaleString() + '</p>' +
            '<div class="thumb-strip">' + cfLookData.images.map(function(img, i) {
              return '<div class="thumb-strip-item ' + (i === cfCurrentIndex ? 'active-thumb' : '') + '" style="background-image:url(\'' + img + '\');" data-index="' + i + '"></div>';
            }).join('') + '</div>' +
            '<p class="text-[0.62rem] text-neutral-400 mt-1">Image ' + (cfCurrentIndex + 1) + ' of ' + cfLookData.images.length + ' — Click thumbnails or use arrows</p>' +
          '</div>' +
          '<div class="flex gap-2 mt-5 pt-4 border-t border-gray-100">' +
            '<a href="collection.html" class="btn-primary flex-1 text-center text-[0.7rem] py-2.5">Shop This Look</a>' +
            '<a href="fitting.html" class="btn-outline flex-1 text-center text-[0.7rem] py-2.5">Schedule Fitting</a>' +
          '</div>';

        sidebar.querySelectorAll('.thumb-strip-item').forEach(function(thumb) {
          thumb.addEventListener('click', function() { cfCurrentIndex = parseInt(this.dataset.index); updateCenterfold(); });
        });
      }

      document.getElementById('cfPrev').addEventListener('click', function() {
        if (!cfLookData) return;
        cfCurrentIndex = (cfCurrentIndex - 1 + cfLookData.images.length) % cfLookData.images.length;
        updateCenterfold();
      });
      document.getElementById('cfNext').addEventListener('click', function() {
        if (!cfLookData) return;
        cfCurrentIndex = (cfCurrentIndex + 1) % cfLookData.images.length;
        updateCenterfold();
      });

      document.addEventListener('keydown', function(e) {
        if (!document.getElementById('centerfoldOverlay').classList.contains('open')) return;
        if (e.key === 'Escape') closeCenterfold();
        if (e.key === 'ArrowLeft' && cfLookData) { cfCurrentIndex = (cfCurrentIndex - 1 + cfLookData.images.length) % cfLookData.images.length; updateCenterfold(); }
        if (e.key === 'ArrowRight' && cfLookData) { cfCurrentIndex = (cfCurrentIndex + 1) % cfLookData.images.length; updateCenterfold(); }
      });

      var touchStartX = 0;
      document.getElementById('centerfoldMain').addEventListener('touchstart', function(e) { touchStartX = e.changedTouches[0].screenX; });
      document.getElementById('centerfoldMain').addEventListener('touchend', function(e) {
        if (!cfLookData) return;
        var diff = e.changedTouches[0].screenX - touchStartX;
        if (Math.abs(diff) > 50) {
          if (diff < 0) cfCurrentIndex = (cfCurrentIndex + 1) % cfLookData.images.length;
          else cfCurrentIndex = (cfCurrentIndex - 1 + cfLookData.images.length) % cfLookData.images.length;
          updateCenterfold();
        }
      });

      document.getElementById('centerfoldClose').addEventListener('click', closeCenterfold);
      document.getElementById('centerfoldOverlay').addEventListener('click', function(e) { if (e.target === this) closeCenterfold(); });

      function renderGrid(page) {
        currentPage = page;
        var start = page * looksPerPage;
        var pageLooks = looks.slice(start, start + looksPerPage);
        document.getElementById('lookGrid').innerHTML = pageLooks.map(function(look) {
          return '<div class="look-card">' +
            '<img src="' + look.images[0] + '" alt="' + look.name + '" loading="lazy" onerror="this.src=\'https://placehold.co/400x350/e5e7eb/9ca3af?text=' + encodeURIComponent(look.name) + '\'">' +
            '<div class="look-overlay text-white">' +
              '<h3 class="text-lg font-medium">' + look.name + '</h3>' +
              '<p class="text-[0.65rem] opacity-80 mt-1">' + look.occasion + ' · ₦' + look.price.toLocaleString() + '</p>' +
              '<button class="bg-white text-[#374151] px-4 py-2 text-[0.65rem] font-medium rounded-lg mt-3 open-centerfold" data-look="' + look.id + '">View Details</button>' +
            '</div>' +
          '</div>';
        }).join('');
        document.querySelectorAll('.page-dot').forEach(function(d, i) { d.classList.toggle('active-dot', i === page); });
        document.querySelectorAll('.open-centerfold').forEach(function(btn) {
          btn.addEventListener('click', function(e) { e.stopPropagation(); openCenterfold(this.dataset.look); });
        });
        document.querySelectorAll('.look-card').forEach(function(card) {
          card.addEventListener('click', function() { var btn = this.querySelector('.open-centerfold'); if (btn) openCenterfold(btn.dataset.look); });
        });
      }

      document.getElementById('prevPage').addEventListener('click', function() { if (currentPage > 0) renderGrid(currentPage - 1); });
      document.getElementById('nextPage').addEventListener('click', function() { if (currentPage < totalPages - 1) renderGrid(currentPage + 1); });
      document.querySelectorAll('.page-dot').forEach(function(dot) { dot.addEventListener('click', function() { renderGrid(parseInt(this.dataset.page)); }); });
      document.querySelectorAll('.detail-chip').forEach(function(chip) {
        chip.addEventListener('click', function() {
          document.querySelectorAll('.detail-chip').forEach(function(c) { c.classList.remove('active-chip'); });
          this.classList.add('active-chip');
        });
      });

      renderGrid(0);
    })();
  </script>
