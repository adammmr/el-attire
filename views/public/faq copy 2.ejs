                    default:
                        "Thanks! A support agent will respond shortly. For immediate help: +234 800 000 0000 (Mon-Sat, 8am-8pm).",
                };
                function getReply(m) {
                    var x = m.toLowerCase();
                    if (x.indexOf("tailor") > -1 || x.indexOf("kaftan") > -1 || x.indexOf("agbada") > -1)
                        return replies.tailor;
                    if (x.indexOf("ship") > -1 || x.indexOf("deliver") > -1) return replies.ship;
                    if (x.indexOf("pay") > -1 || x.indexOf("card") > -1 || x.indexOf("price") > -1) return replies.pay;
                    return replies.default;
                }
                function getTime() {
                    return new Date().toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: true });
                }
                function addMsg(text, type) {
                    var msgs = document.getElementById("cwMessages");
                    var b = document.createElement("div");
                    b.className = "cw-bub " + (type === "sent" ? "out" : "in");
                    b.innerHTML = text + '<span class="cw-t">' + getTime() + "</span>";
                    msgs.appendChild(b);
                    msgs.scrollTop = msgs.scrollHeight;
                }
                function sendMsg() {
                    var input = document.getElementById("cwInput");
                    if (!input || !input.value.trim()) return;
                    var msg = input.value.trim();
                    addMsg(msg, "sent");
                    input.value = "";
                    setTimeout(
                        function () {
                            addMsg(getReply(msg), "received");
                        },
                        700 + Math.random() * 1000
                    );
                }
                function sendQuick(text) {
                    var input = document.getElementById("cwInput");
                    if (input) input.value = text;
                    sendMsg();
                }
                function open() {
                    widget.classList.add("open");
                    isOpen = true;
                    setTimeout(function () {
                        var inp = document.getElementById("cwInput");
                        if (inp) inp.focus();
                    }, 300);
                }
                function close() {
                    widget.classList.remove("open");
                    isOpen = false;
                }
                function toggle() {
                    isOpen ? close() : open();
                }
                document.getElementById("cwCloseBtn").addEventListener("click", close);
                document.getElementById("cwSendBtn").addEventListener("click", sendMsg);
                document.getElementById("cwInput").addEventListener("keypress", function (e) {
                    if (e.key === "Enter") sendMsg();
                });
                document.getElementById("cwQuickTailoring").addEventListener("click", function () {
                    sendQuick("Tailoring info");
                });
                document.getElementById("cwQuickShipping").addEventListener("click", function () {
                    sendQuick("Shipping info");
                });
                document.getElementById("cwQuickPayment").addEventListener("click", function () {
                    sendQuick("Payment methods");
                });
                document.addEventListener("keydown", function (e) {
                    if (e.key === "Escape" && isOpen) close();
                });
                document.addEventListener("click", function (e) {
                    if (
                        isOpen &&
                        !widget.contains(e.target) &&
                        e.target.id !== "supportHeaderToggle" &&
                        !document.getElementById("supportHeaderToggle").contains(e.target)
                    )
                        close();
                });
                document.getElementById("supportHeaderToggle").addEventListener("click", toggle);
            })();
        </script>

        <!-- FAQ Script -->
        <script>
            (function () {
                window.toggleFaq = function (question) {
                    var item = question.parentElement;
                    var isOpen = item.classList.contains("open");
                    document.querySelectorAll(".faq-item").forEach(function (i) {
                        i.classList.remove("open");
                    });
                    if (!isOpen) item.classList.add("open");
                };

                var categoryBtns = document.querySelectorAll(".category-btn");
                categoryBtns.forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        categoryBtns.forEach(function (b) {
                            b.classList.remove("active-cat");
                        });
                        this.classList.add("active-cat");
                        filterFAQs(this.dataset.cat, document.getElementById("faqSearch").value);
                    });
                });

                document.getElementById("faqSearch").addEventListener("input", function () {
                    var activeCat = document.querySelector(".category-btn.active-cat").dataset.cat;
                    filterFAQs(activeCat, this.value);
                });

                window.filterFAQs = function (category, searchTerm) {
                    var items = document.querySelectorAll(".faq-item");
                    var visibleCount = 0;
                    items.forEach(function (item) {
                        var cat = item.dataset.cat;
                        var text = item.textContent.toLowerCase();
                        var matchesCat = category === "all" || cat === category;
                        var matchesSearch = !searchTerm || text.indexOf(searchTerm.toLowerCase()) > -1;
                        if (matchesCat && matchesSearch) {
                            item.style.display = "block";
                            visibleCount++;
                        } else {
                            item.style.display = "none";
                            item.classList.remove("open");
                        }
                    });
                    document.getElementById("noResults").classList.toggle("hidden", visibleCount > 0);
                };

                // Open first item by default
                var firstItem = document.querySelector(".faq-item");
                if (firstItem) firstItem.classList.add("open");
            })();
        </script>
    