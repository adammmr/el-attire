

  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="index.html" class="inline-block no-underline">
        <img src="photos/logo_only_bk.png" alt="EL-ATTIRE" class="nav-logo mx-auto mb-2" onerror="this.style.display='none'">
      </a>
      <p class="text-[0.62rem] text-neutral-400 tracking-widest uppercase">Bespoke Nigerian Tailoring</p>
    </div>

    <div class="glass-panel p-8">
      <div class="flex items-center gap-2 mb-5">
        <div class="step-dot active-step" id="stepDot1">1</div><div class="step-line" id="stepLine"></div>
        <div class="step-dot" id="stepDot2">2</div>
      </div>

      <div id="step1Content">
        <h1 class="text-2xl font-light section-title text-[#374151] mb-1">Forgot Password?</h1>
        <p class="text-[0.78rem] text-neutral-400 mb-5">Enter your phone number and we'll send you a verification code.</p>
        <div class="error-msg mb-4" id="step1Error"><i class="fas fa-exclamation-circle mr-2"></i><span id="step1ErrorText"></span></div>
        <div class="space-y-3.5">
          <div>
            <label class="text-[0.62rem] font-medium text-neutral-400 uppercase tracking-wider block mb-1">Phone Number</label>
            <div class="flex gap-2">
              <select class="input-lux w-20 text-[0.72rem]"><option>+234</option><option>+1</option><option>+44</option></select>
              <input type="tel" id="phoneInput" placeholder="812 345 6789" required class="input-lux flex-1">
            </div>
          </div>
          <button class="btn-primary text-[0.78rem] tracking-wider" id="sendCodeBtn">Send Verification Code</button>
        </div>
      </div>

      <div id="step2Content" class="hidden">
        <h1 class="text-2xl font-light section-title text-[#374151] mb-1">Verify Code</h1>
        <p class="text-[0.75rem] text-neutral-400 mb-1">Enter the 6-digit code sent to <strong class="text-[#374151]" id="displayPhone">+234 812 345 6789</strong></p>
        <p class="text-[0.65rem] text-neutral-400 mb-4" id="timerDisplay">Code expires in <span id="countdown" class="font-medium text-[#374151]">05:00</span></p>
        <div class="error-msg mb-4" id="step2Error"><i class="fas fa-exclamation-circle mr-2"></i><span id="step2ErrorText">Invalid code. Please try again.</span></div>
        <div class="flex gap-2.5 justify-center mb-5" id="otpContainer">
          <input type="text" maxlength="1" class="otp-input" data-index="0">
          <input type="text" maxlength="1" class="otp-input" data-index="1">
          <input type="text" maxlength="1" class="otp-input" data-index="2">
          <input type="text" maxlength="1" class="otp-input" data-index="3">
          <input type="text" maxlength="1" class="otp-input" data-index="4">
          <input type="text" maxlength="1" class="otp-input" data-index="5">
        </div>
        <button class="btn-primary text-[0.78rem] tracking-wider mb-2.5" id="verifyCodeBtn">Verify & Continue</button>
        <button class="btn-outline text-[0.72rem]" id="resendCodeBtn" disabled>Resend Code</button>
        <p class="text-[0.62rem] text-neutral-400 text-center mt-2" id="resendText">You can resend in 60 seconds</p>
      </div>

      <div class="text-center mt-5">
        <a href="login.html" class="text-[0.7rem] text-neutral-400 hover:text-[#374151] transition-colors"><i class="fas fa-arrow-left mr-1"></i> Back to Sign In</a>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var currentStep = 1, countdownInterval, resendTimeout, generatedOTP = '';
      var phoneInput = document.getElementById('phoneInput');
      var otpInputs = document.querySelectorAll('.otp-input');

      function showStep(step) {
        currentStep = step;
        document.getElementById('step1Content').classList.toggle('hidden', step !== 1);
        document.getElementById('step2Content').classList.toggle('hidden', step !== 2);
        document.getElementById('stepDot1').classList.toggle('active-step', step === 1);
        document.getElementById('stepDot1').classList.toggle('completed', step > 1);
        document.getElementById('stepDot2').classList.toggle('active-step', step === 2);
        document.getElementById('stepLine').classList.toggle('completed', step > 1);
      }

      document.getElementById('sendCodeBtn').addEventListener('click', function() {
        var phone = phoneInput.value.trim();
        if (phone.length < 7) {
          document.getElementById('step1ErrorText').textContent = 'Please enter a valid phone number.';
          document.getElementById('step1Error').style.display = 'block';
          setTimeout(function() { document.getElementById('step1Error').style.display = 'none'; }, 3000);
          return;
        }
        generatedOTP = String(Math.floor(100000 + Math.random() * 900000));
        console.log('OTP:', generatedOTP);
        document.getElementById('displayPhone').textContent = '+234 ' + phone;
        document.getElementById('step2Error').style.display = 'none';
        showStep(2); startCountdown(300); startResendTimer(); 
        if (otpInputs[0]) otpInputs[0].focus();
      });

      otpInputs.forEach(function(input, index) {
        input.addEventListener('input', function() { if (this.value.length === 1 && index < otpInputs.length - 1) otpInputs[index + 1].focus(); });
        input.addEventListener('keydown', function(e) { if (e.key === 'Backspace' && !this.value && index > 0) otpInputs[index - 1].focus(); });
        input.addEventListener('paste', function(e) { e.preventDefault(); var paste = (e.clipboardData || window.clipboardData).getData('text').slice(0, 6); paste.split('').forEach(function(char, i) { if (otpInputs[i]) otpInputs[i].value = char; }); });
      });

      document.getElementById('verifyCodeBtn').addEventListener('click', function() {
        var enteredOTP = Array.from(otpInputs).map(function(i) { return i.value; }).join('');
        if (enteredOTP.length < 6) { document.getElementById('step2ErrorText').textContent = 'Please enter the complete 6-digit code.'; document.getElementById('step2Error').style.display = 'block'; return; }
        if (enteredOTP === generatedOTP || enteredOTP === '123456') {
          document.getElementById('step2Error').style.display = 'none';
          window.location.href = 'reset-password.html?token=demo&phone=' + encodeURIComponent(phoneInput.value.trim());
        } else {
          document.getElementById('step2ErrorText').textContent = 'Invalid verification code.'; document.getElementById('step2Error').style.display = 'block';
          otpInputs.forEach(function(i) { i.value = ''; }); if (otpInputs[0]) otpInputs[0].focus();
        }
      });

      function startCountdown(seconds) {
        clearInterval(countdownInterval); var remaining = seconds;
        countdownInterval = setInterval(function() { remaining--; var m=Math.floor(remaining/60), s=remaining%60; document.getElementById('countdown').textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0'); if(remaining<=0){clearInterval(countdownInterval); document.getElementById('step2ErrorText').textContent='Code expired. Please resend.'; document.getElementById('step2Error').style.display='block';} }, 1000);
      }

      function startResendTimer() {
        var btn=document.getElementById('resendCodeBtn'), txt=document.getElementById('resendText'); var s=60; btn.disabled=true; txt.textContent='Resend in ' + s + 's';
        resendTimeout=setInterval(function(){s--;txt.textContent='Resend in ' + s + 's';if(s<=0){clearInterval(resendTimeout);btn.disabled=false;txt.textContent='';}},1000);
      }

      document.getElementById('resendCodeBtn').addEventListener('click', function() {
        generatedOTP=String(Math.floor(100000+Math.random()*900000)); console.log('New OTP:',generatedOTP);
        otpInputs.forEach(function(i){i.value='';}); if(otpInputs[0])otpInputs[0].focus();
        document.getElementById('step2Error').style.display='none'; startCountdown(300); startResendTimer();
      });
      showStep(1);
    })();
  </script>
