                        custom: "✂️ Want custom measurements? Book a fitting and our master tailors will create your perfect piece.",
                        default: "Thanks! A consultant will respond shortly. +234 800 000 0000.",
                    };
                function getReply(m) {
                    var x = m.toLowerCase();
                    if (x.includes("size") || x.includes("fit")) return replies.size;
                    if (x.includes("ship") || x.includes("deliver")) return replies.ship;
                    if (x.includes("custom") || x.includes("tailor")) return replies.custom;
                    return replies.default;
                }
                function getTime() {
                    return new Date().toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: true });
                }
                function addMsg(t, ty) {
                    var ms = document.getElementById("cwMessages"),
                        b = document.createElement("div");
                    b.className = "cw-bub " + (ty === "sent" ? "out" : "in");
                    b.innerHTML = t + '<span class="cw-t">' + getTime() + "</span>";
                    ms.appendChild(b);
                    ms.scrollTop = ms.scrollHeight;
                }
                function sendMsg() {
                    var inp = document.getElementById("cwInput");
                    if (!inp || !inp.value.trim()) return;
                    var m = inp.value.trim();
                    addMsg(m, "sent");
                    inp.value = "";
                    setTimeout(
                        function () {
                            addMsg(getReply(m), "received");
                        },
                        700 + Math.random() * 1000
                    );
                }
                function sendQuick(t) {
                    var inp = document.getElementById("cwInput");
                    if (inp) inp.value = t;
                    sendMsg();
                }
                function open() {
                    widget.classList.add("open");
                    isOpen = true;
                    setTimeout(function () {
                        var i = document.getElementById("cwInput");
                        if (i) i.focus();
                    }, 300);
                }
                function close() {
                    widget.classList.remove("open");
                    isOpen = false;
                }
                function toggle() {
                    isOpen ? close() : open();
                }
                document.getElementById("cwCloseBtn").addEventListener("click", close);
                document.getElementById("cwSendBtn").addEventListener("click", sendMsg);
                document.getElementById("cwInput").addEventListener("keypress", function (e) {
                    if (e.key === "Enter") sendMsg();
                });
                document.getElementById("cwQuickSize").addEventListener("click", function () {
                    sendQuick("Sizing");
                });
                document.getElementById("cwQuickShip").addEventListener("click", function () {
                    sendQuick("Shipping");
                });
                document.getElementById("cwQuickCustom").addEventListener("click", function () {
                    sendQuick("Custom order");
                });
                document.addEventListener("keydown", function (e) {
                    if (e.key === "Escape" && isOpen) close();
                });
                document.addEventListener("click", function (e) {
                    if (
                        isOpen &&
                        !widget.contains(e.target) &&
                        e.target.id !== "supportHeaderToggle" &&
                        !document.getElementById("supportHeaderToggle").contains(e.target)
                    )
                        close();
                });
                document.getElementById("supportHeaderToggle").addEventListener("click", toggle);
            })();
        </script>

